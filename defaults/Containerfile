# aidock: Agent-agnostic AI dev container
# Provides LSPs, formatters, toolchains, and AI coding agents (copilot, claude, codex).
# Build: just build
# See justfile for convenience recipes

FROM fedora:latest

ARG PROJECT_NAME

# ── Base system tools ────────────────────────────────────────────────
RUN dnf install -y \
        # Version control
        git git-lfs openssh-clients \
        # Networking
        curl wget ca-certificates \
        # Search & navigation
        jq ripgrep fd-find tree file less \
        # Archives
        tar gzip xz unzip p7zip \
        # Text & data
        diffutils patch bc man-db man-pages \
        # Process management
        which procps-ng findutils \
        # Runtimes & compilers
        nodejs npm python3 python3-pip golang \
        # Build systems
        make cmake gcc gcc-c++ clang-tools-extra \
        # Debugging & profiling
        gdb valgrind strace ltrace \
        # Document analysis
        poppler-utils tesseract w3m xmlstarlet pandoc \
        # Image manipulation
        ImageMagick \
        # Database
        sqlite \
        # Shell tools
        ShellCheck just sudo \
    && dnf clean all

# ── LSPs and MCP servers via npm ─────────────────────────────────────
RUN npm install -g \
        typescript \
        typescript-language-server \
        bash-language-server \
        dockerfile-language-server-nodejs \
        yaml-language-server \
        vscode-langservers-extracted \
        @upstash/context7-mcp \
        @modelcontextprotocol/server-sequential-thinking \
        @playwright/mcp \
        firecrawl-mcp \
    && npm cache clean --force

# ── Python packages (LSP, formatters, document & image libraries) ──────
RUN pip install --break-system-packages \
        basedpyright ruff openpyxl Pillow python-docx

# ── Formatters ────────────────────────────────────────────────────────
RUN npm install -g prettier

# ── Git identity for container sessions ──────────────────────────────
RUN printf '[user]\n\tname = AI Coding Agent\n\temail = noreply@github.com\n' \
    > /etc/gitconfig

# ── Writable home for container user mapping ─────────────────────────
RUN mkdir -p /home/${PROJECT_NAME} && chmod -R 777 /home/${PROJECT_NAME}
# Allow entrypoint to add passwd entry for Docker --user (no-op under Podman)
RUN chmod 666 /etc/passwd /etc/group
# Passwordless sudo: lets Docker-mapped users install packages at runtime.
# Under Podman (--userns=keep-id:uid=0), the agent is already root so sudo is unnecessary.
RUN echo "ALL ALL=(ALL) NOPASSWD: ALL" > /etc/sudoers.d/agent
ENV HOME="/home/${PROJECT_NAME}"

# ── AI coding agents ──────────────────────────────────────────────────
RUN npm install -g \
        @github/copilot \
        @anthropic-ai/claude-code \
        @openai/codex \
    && npm cache clean --force

# ── Entrypoint & healthcheck ──────────────────────────────────────────
COPY --chmod=755 init-home.sh /usr/local/bin/init-home.sh
COPY --chmod=755 checkhealth.sh /usr/local/bin/checkhealth.sh

ENV PROJECT_NAME="${PROJECT_NAME}"

ENTRYPOINT ["/usr/local/bin/init-home.sh"]
