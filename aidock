#!/usr/bin/env bash
# aidock: Launch an AI coding agent inside a container (podman or docker).
# This file is the distributed launcher: copy it onto your PATH (e.g. via
# `just install`) and run it directly. There is no dist/build step.
# PROJECT_NAME defaults to "aidock" but can be overridden by env (e.g. tests).

set -euo pipefail

: "${PROJECT_NAME:=aidock}"

# ── Hidden subcommands (run inside the container) ────────────────────
# Container entrypoint and healthcheck. These are dispatched *before* any
# other launcher logic runs, so they're cheap and side-effect-free on the host.

cmd_init_home() {
    # Per-container entrypoint. Ensures a writable home for the current UID
    # and applies agent-specific post-assembly. Required env (set by aidock):
    : "${AGENT:?}" "${AGENT_CONFIG_DIR:?}" "${PROJECT_NAME:?}"

    # Ensure current UID has a passwd entry (Docker --user; no-op as root)
    if [[ "$(id -u)" != "0" ]] && ! getent passwd "$(id -u)" &>/dev/null; then
        echo "${PROJECT_NAME}:x:$(id -u):$(id -g)::${HOME}:/bin/bash" >>/etc/passwd
    fi

    local config_target="${HOME}/${AGENT_CONFIG_DIR}"
    mkdir -p "${config_target}"

    # Reduce false-positive index churn between host and container
    if git rev-parse --git-dir &>/dev/null; then
        git config core.checkstat minimal
    fi

    exec "$@"
}

cmd_checkhealth() {
    # Verify the container environment is correctly configured.
    # Run via: aidock check
    set -uo pipefail
    : "${AGENT:?}" "${AGENT_CONFIG_DIR:?}" "${PROJECT_NAME:?}"

    local PASS=0 FAIL=0 WARN=0
    pass() {
        printf "  \033[32m✓\033[0m %s\n" "$1"
        PASS=$((PASS + 1))
    }
    fail() {
        printf "  \033[31m✗\033[0m %s\n" "$1"
        FAIL=$((FAIL + 1))
    }
    warn() {
        printf "  \033[33m!\033[0m %s\n" "$1"
        WARN=$((WARN + 1))
    }
    section() { printf "\n\033[1;36m── %s ──\033[0m\n" "$1"; }

    check_bin() {
        local name="$1" path="$2"
        if [[ "$path" == "PATH" ]]; then
            if command -v "$name" &>/dev/null; then
                pass "$name ($(command -v "$name"))"
            else
                fail "$name not found in PATH"
            fi
        elif [[ -x "$path" ]]; then
            pass "$name ($path)"
        else
            fail "$name not found at $path"
        fi
    }

    # ── Environment ──────────────────────────────────────────────────
    section "Environment"
    pass "AGENT=$AGENT"
    pass "AGENT_CONFIG_DIR=$AGENT_CONFIG_DIR"
    pass "PROJECT_NAME=$PROJECT_NAME"

    if [[ -d "$HOME" ]] && [[ -w "$HOME" ]]; then
        pass "HOME=$HOME (writable)"
    else
        fail "HOME=$HOME (not writable)"
    fi

    if touch "$HOME/.checkhealth-test" 2>/dev/null; then
        rm -f "$HOME/.checkhealth-test"
        pass "HOME write test"
    else
        fail "HOME write test"
    fi

    if [[ -n "${TERM:-}" ]]; then pass "TERM=$TERM"; else warn "TERM not set"; fi
    if [[ -n "${LANG:-}" ]]; then pass "LANG=$LANG"; else warn "LANG not set"; fi

    local id_output
    id_output="$(id -u):$(id -g) ($(whoami 2>/dev/null || echo 'unknown'))"
    pass "UID:GID = $id_output"

    # ── CWD & mounts ─────────────────────────────────────────────────
    section "CWD & mounts"
    local cwd
    cwd="$(pwd)"
    pass "CWD=$cwd"

    if [[ -d "$cwd" && -r "$cwd" ]]; then pass "CWD is readable"; else fail "CWD is not readable"; fi
    if [[ -w "$cwd" ]]; then pass "CWD is writable"; else fail "CWD is not writable"; fi

    if touch "$cwd/.checkhealth-mount-test" 2>/dev/null; then
        rm -f "$cwd/.checkhealth-mount-test"
        pass "CWD write test"
    else
        fail "CWD write test (mount may be ro)"
    fi

    # ── Agent CLI ────────────────────────────────────────────────────
    section "Agent CLI ($AGENT)"
    case "$AGENT" in
        copilot)
            if command -v copilot &>/dev/null; then
                pass "copilot ($(copilot --version 2>/dev/null || echo unknown))"
            else
                fail "copilot not found"
            fi
            ;;
        claude)
            if command -v claude &>/dev/null; then
                pass "claude ($(claude --version 2>/dev/null || echo unknown))"
            else
                fail "claude not found"
            fi
            ;;
        codex)
            if command -v codex &>/dev/null; then
                pass "codex ($(codex --version 2>/dev/null || echo unknown))"
            else
                fail "codex not found"
            fi
            ;;
    esac

    # ── Authentication ───────────────────────────────────────────────
    section "Authentication"
    case "$AGENT" in
        copilot)
            if [[ -n "${GH_TOKEN:-}" ]]; then
                pass "GH_TOKEN set (${GH_TOKEN:0:4}...${GH_TOKEN: -4})"
            else
                fail "GH_TOKEN not set (copilot will not authenticate)"
            fi
            ;;
        claude)
            if [[ -n "${ANTHROPIC_API_KEY:-}" ]]; then
                pass "ANTHROPIC_API_KEY set (${ANTHROPIC_API_KEY:0:4}...${ANTHROPIC_API_KEY: -4})"
            else
                warn "ANTHROPIC_API_KEY not set (claude will not authenticate)"
            fi
            ;;
        codex)
            if [[ -n "${OPENAI_API_KEY:-}" ]]; then
                pass "OPENAI_API_KEY set (${OPENAI_API_KEY:0:4}...${OPENAI_API_KEY: -4})"
            else
                warn "OPENAI_API_KEY not set (codex will not authenticate)"
            fi
            ;;
    esac

    # ── Host config bind mounts ──────────────────────────────────────
    section "Host config bind mounts"
    # Each entry: "<container-path>|<credential?>" — credential entries
    # FAIL if missing, others WARN. Mirrors add_host_config_mount cases.
    local mount_entries=()
    case "$AGENT" in
        copilot)
            mount_entries=(
                "${HOME}/.config/github-copilot/apps.json|cred"
                "${HOME}/.config/github-copilot/versions.json|opt"
                "${HOME}/.config/github-copilot/hosts.json|opt"
                "${HOME}/.config/github-copilot/settings.json|opt"
                "${HOME}/.config/github-copilot/skills|opt"
            )
            ;;
        claude)
            mount_entries=(
                "${HOME}/.claude/.credentials.json|cred"
                "${HOME}/.claude/settings.json|opt"
                "${HOME}/.claude/CLAUDE.md|opt"
            )
            ;;
        codex)
            mount_entries=(
                "${HOME}/.codex/auth.json|cred"
                "${HOME}/.codex/config.toml|opt"
                "${HOME}/.codex/AGENTS.md|opt"
            )
            ;;
    esac
    local entry path kind label
    for entry in "${mount_entries[@]}"; do
        path="${entry%|*}"
        kind="${entry##*|}"
        label="${path#"${HOME}/"}"
        if [[ -e "$path" && -r "$path" ]]; then
            pass "$label (mounted)"
        elif [[ "$kind" == "cred" ]]; then
            fail "$label not mounted (auth will fail; check host file exists)"
        else
            warn "$label not mounted (optional; create on host to use)"
        fi
    done

    section "Toolchains"
    if command -v node &>/dev/null; then pass "node $(node --version)"; else fail "node not found"; fi
    if command -v python3 &>/dev/null; then pass "python3 $(python3 --version 2>&1 | awk '{print $2}')"; else fail "python3 not found"; fi

    # ── Formatters & linters ─────────────────────────────────────────
    section "Formatters & linters"
    check_bin "ruff" "PATH"
    check_bin "prettier" "PATH"
    check_bin "shellcheck" "PATH"

    # ── Dev tools ────────────────────────────────────────────────────
    section "Dev tools"
    local tool
    for tool in git jq rg fd just curl; do
        check_bin "$tool" "PATH"
    done

    # ── Git ──────────────────────────────────────────────────────────
    section "Git"
    local git_name git_email
    git_name=$(git config --get user.name 2>/dev/null || echo "")
    git_email=$(git config --get user.email 2>/dev/null || echo "")
    if [[ -n "$git_name" && -n "$git_email" ]]; then
        pass "identity: $git_name <$git_email>"
    else
        fail "git identity not configured"
    fi

    if git rev-parse --git-dir &>/dev/null; then
        local checkstat
        checkstat=$(git config --get core.checkstat 2>/dev/null || echo "")
        if [[ "$checkstat" == "minimal" ]]; then
            pass "core.checkstat=minimal (reindex protection)"
        else
            warn "core.checkstat not set (entrypoint sets this per-project)"
        fi
        pass "inside git repo: $(git rev-parse --show-toplevel 2>/dev/null)"
    else
        warn "not inside a git repo (core.checkstat test skipped)"
    fi

    # ── Summary ──────────────────────────────────────────────────────
    printf "\n\033[1m── Summary ──\033[0m\n"
    printf "  \033[32m%d passed\033[0m" "$PASS"
    [[ $WARN -gt 0 ]] && printf "  \033[33m%d warnings\033[0m" "$WARN"
    [[ $FAIL -gt 0 ]] && printf "  \033[31m%d failed\033[0m" "$FAIL"
    printf "\n"
    return "$FAIL"
}

case "${1:-}" in
    __init-home)
        shift
        cmd_init_home "$@"
        # cmd_init_home ends with exec, so we never get here
        exit 0
        ;;
    __checkhealth)
        shift
        cmd_checkhealth "$@"
        exit "$?"
        ;;
esac

readonly AVAILABLE_AGENTS="copilot claude codex"

usage() {
    cat <<EOF
Usage: ${0##*/} [command] [options] [-- agent args...]

Launch an AI coding agent inside a container.

Commands:
  run            Launch agent in container (default if omitted)
  update         Update AI agents in the shared agents volume (global)
  clean          Remove image, config, and dangling layers
  shell          Open a debug shell in container
  info           Show engine, image, and agent info
  drop-session   Remove this CWD's session image + record (next run uses base)
  purge          Delete config + session data (with confirmation)
  list-sessions  List recorded per-CWD sessions
  prune          Show (or remove with --orphans) sessions whose CWD is gone

Options:
  -a, --agent NAME   Agent to run (${AVAILABLE_AGENTS// /, }). Default: copilot
  -n, --dry-run      Print container command without executing
  --no-cache         Force a no-cache base image rebuild on this invocation
  -h, --help         Show this help
  -v, --version      Show version

Command-specific options:
  run:           --no-rebuild  Skip auto-rebuild check
                 --commit POLICY  Override commit_on_exit (always|prompt|never)
  shell:         --commit POLICY  Override commit_on_exit (always|prompt|never)
  purge:         --force       Skip confirmation prompt (for scripting)
                 -a, --agent NAME  Restrict purge to one agent's data dir
  prune:         --orphans     Actually remove orphan sessions (default: dry-run)

Agent args:
  Arguments after -- are passed to the agent binary.
  Example: ${0##*/} -a claude -- --verbose

Configuration:
  Agent config+state: \${XDG_CONFIG_HOME:-~/.config}/${PROJECT_NAME}/<agent>/
  Build files:        \${XDG_CONFIG_HOME:-~/.config}/${PROJECT_NAME}/Containerfile
                      All seeded from defaults on first run. Edit to customize.
  Default agent:      \${XDG_CONFIG_HOME:-~/.config}/${PROJECT_NAME}/default-agent
  Container args:     \${XDG_CONFIG_HOME:-~/.config}/${PROJECT_NAME}/container.conf
  aidock settings:    \${XDG_CONFIG_HOME:-~/.config}/${PROJECT_NAME}/aidock.conf

Examples:
  ${0##*/}                           # Run default agent (copilot)
  ${0##*/} -a claude                 # Run Claude Code
  ${0##*/} shell                     # Debug shell
  ${0##*/} info                      # Show diagnostic info
  ${0##*/} purge -a claude --force  # Delete all claude config + session data
  ${0##*/} drop-session              # Reset this CWD's session image to base
  ${0##*/} --no-cache                 # Force a no-cache base image rebuild
  ${0##*/} -a claude -- --verbose    # Pass --verbose to claude
  ${0##*/} -- --help                 # Show agent's own help
EOF
    exit 0
}

# ── Engine detection ─────────────────────────────────────────────────

detect_engine() {
    if [[ -n "${CONTAINER_ENGINE:-}" ]]; then
        ENGINE="$CONTAINER_ENGINE"
        if ! command -v "$ENGINE" &>/dev/null; then
            echo "error: CONTAINER_ENGINE='$ENGINE' not found" >&2
            exit 1
        fi
    elif command -v podman &>/dev/null; then
        ENGINE="podman"
    elif command -v docker &>/dev/null; then
        ENGINE="docker"
    else
        echo "error: neither podman nor docker found" >&2
        exit 1
    fi
}

detect_engine

# ── Engine wrapper functions ─────────────────────────────────────────

engine_build() { "$ENGINE" build "$@"; }

engine_image_exists() {
    if [[ "$ENGINE" == "podman" ]]; then
        "$ENGINE" image exists "$1" 2>/dev/null
    else
        "$ENGINE" image inspect "$1" &>/dev/null
    fi
}

# Print human-readable size for an image tag (e.g. "412 MB"), or empty
# string when the image is missing.
engine_image_size() {
    local tag="$1"
    "$ENGINE" images --format '{{.Size}}' "$tag" 2>/dev/null | head -n1
}

# ── Shared agents volume helpers ─────────────────────────────────────
# The agents volume holds the npm-installed agent CLIs (copilot/claude/
# codex) and is mounted at /opt/aidock/agents on every container run.
# It is populated at build time (cmd_build → _seed_agents_volume) and
# refreshed by `update-agents` so updates propagate instantly to all
# CWDs/sessions without any per-session rebuild.

engine_volume_exists() {
    "$ENGINE" volume inspect "$1" &>/dev/null
}

engine_volume_create() {
    if ! engine_volume_exists "$1"; then
        "$ENGINE" volume create "$1" >/dev/null
    fi
}

# Best-effort human-readable size for a named volume (e.g. "47M"); empty
# string when the volume is missing or its mountpoint is unreadable.
engine_volume_size() {
    local mp
    mp=$("$ENGINE" volume inspect --format '{{.Mountpoint}}' "$1" 2>/dev/null) || return 0
    [[ -d "$mp" && -r "$mp" ]] || return 0
    du -sh "$mp" 2>/dev/null | cut -f1
}

# engine_run execs into the container — this function does not return.
# In dry-run mode, prints the command instead of executing.
# Used for ephemeral commands (check) that must not commit.
engine_run() {
    local userns_flag=()
    if [[ "$ENGINE" == "podman" ]]; then
        # shellcheck disable=SC2054  # comma is part of podman flag syntax, not array separator
        userns_flag=(--userns=keep-id:uid=0,gid=0)
    else
        userns_flag=(--user "$(id -u):$(id -g)")
    fi
    if [[ "$DRY_RUN" == "true" ]]; then
        local cmd
        cmd=$(printf '%q ' "$ENGINE" run "${userns_flag[@]}" "$@")
        cmd=$(echo "$cmd" | sed -E 's/(GH_TOKEN=|ANTHROPIC_API_KEY=|OPENAI_API_KEY=)[^ ]*/\1***REDACTED***/g')
        echo "$cmd"
        exit 0
    fi
    exec "$ENGINE" run "${userns_flag[@]}" "$@"
}

# engine_run_committing runs the container without --rm, waits for it
# to exit, and then applies the COMMIT_POLICY: empty diff or 'never'
# discards; 'always' commits to SESSION_IMAGE_NAME; 'prompt' asks the
# user with a 10s default-yes timeout. Always removes the container
# afterwards. Exits with the container's exit code.
#
# Callers must NOT pass --rm; this function manages container lifetime.
engine_run_committing() {
    local userns_flag=()
    if [[ "$ENGINE" == "podman" ]]; then
        # shellcheck disable=SC2054
        userns_flag=(--userns=keep-id:uid=0,gid=0)
    else
        userns_flag=(--user "$(id -u):$(id -g)")
    fi
    if [[ "$DRY_RUN" == "true" ]]; then
        local cmd
        cmd=$(printf '%q ' "$ENGINE" run "${userns_flag[@]}" "$@")
        cmd=$(echo "$cmd" | sed -E 's/(GH_TOKEN=|ANTHROPIC_API_KEY=|OPENAI_API_KEY=)[^ ]*/\1***REDACTED***/g')
        echo "$cmd"
        echo "[dry-run] commit_on_exit=${COMMIT_POLICY} (would commit non-empty diff to ${SESSION_IMAGE_NAME})"
        echo "[dry-run] session_lock=${SESSION_DIR}/${SESSION_HASH}.lock"
        exit 0
    fi
    _record_session
    _acquire_session_lock
    local rc=0
    "$ENGINE" run "${userns_flag[@]}" "$@" || rc=$?
    _maybe_commit_container "$CONTAINER_NAME" "$rc"
    exit "$rc"
}

# Persist hash -> CWD mapping so list-sessions and drop-session can
# show meaningful names. Cheap (a tiny file write).
_record_session() {
    mkdir -p "$SESSION_DIR"
    printf '%s\n' "$MOUNT_DIR" >"${SESSION_DIR}/${SESSION_HASH}"
}

# Acquire an exclusive flock on ${SESSION_DIR}/<hash>.lock so concurrent
# invocations on the same CWD don't fight over the session image. On
# contention we fail fast with a friendly error rather than waiting:
# the second invocation almost always indicates user error (forgot a
# session is already open) and silent waits hide that. The lock is
# released automatically on exit (kernel unwinds the open fd).
_acquire_session_lock() {
    if ! command -v flock >/dev/null 2>&1; then
        return 0
    fi
    mkdir -p "$SESSION_DIR"
    local lockfile="${SESSION_DIR}/${SESSION_HASH}.lock"
    exec 9>"$lockfile"
    if ! flock -n 9; then
        {
            echo "error: another aidock session is already running for this CWD"
            echo "  lock: ${lockfile}"
            echo "  exit the other session (or run a different agent in a different CWD) and try again"
        } >&2
        exit 2
    fi
}

# Acquire an exclusive flock on ${SESSION_DIR}/agents-volume.lock so
# concurrent seeds / update-agents on different CWDs don't race against
# the shared agents volume. Uses fd 8 to avoid clashing with the per-CWD
# session lock on fd 9.
_acquire_agents_volume_lock() {
    if ! command -v flock >/dev/null 2>&1; then
        return 0
    fi
    mkdir -p "$SESSION_DIR"
    local lockfile="${SESSION_DIR}/agents-volume.lock"
    exec 8>"$lockfile"
    if ! flock -n 8; then
        {
            echo "error: another aidock build/update-agents is touching the shared agents volume"
            echo "  lock: ${lockfile}"
            echo "  wait for it to finish and try again"
        } >&2
        exit 2
    fi
}

# Map an agent name to its npm package (matches update-agents's table).
_agent_npm_pkg() {
    case "$1" in
        copilot) echo "@github/copilot" ;;
        claude) echo "@anthropic-ai/claude-code" ;;
        codex) echo "@openai/codex" ;;
        *) return 1 ;;
    esac
}

# Install (or refresh) the configured agents into the shared agents
# volume. Called from cmd_build and from the auto-build path so the
# volume is always populated for the agents the user actually has auth
# for. No-op (with info notice) when no agents are configured: the
# picker will already have errored out before reaching a launch path,
# but `aidock build` runs without picker-gating, so we tolerate empty.
_seed_agents_volume() {
    local verb="${1:-Seeding}"
    local pkgs=()
    local a
    while IFS= read -r a; do
        [[ -n "$a" ]] || continue
        pkgs+=("$(_agent_npm_pkg "$a")")
    done < <(list_configured_agents)

    if [[ "$DRY_RUN" == "true" ]]; then
        if [[ ${#pkgs[@]} -eq 0 ]]; then
            echo "[dry-run] would skip agents-volume seed (no configured agents)"
        else
            echo "[dry-run] Would create volume: $ENGINE volume create ${AGENTS_VOLUME}"
            echo "[dry-run] Would seed ${AGENTS_VOLUME}: npm install -g ${pkgs[*]}"
        fi
        return 0
    fi

    if [[ ${#pkgs[@]} -eq 0 ]]; then
        echo "[info] no agents configured on host; skipping agents-volume seed" >&2
        return 0
    fi

    engine_volume_create "$AGENTS_VOLUME"
    _acquire_agents_volume_lock

    echo "${verb} ${AGENTS_VOLUME} with: ${pkgs[*]}"
    local userns_flag=()
    if [[ "$ENGINE" == "podman" ]]; then
        # shellcheck disable=SC2054  # comma is part of podman flag syntax, not array separator
        userns_flag=(--userns=keep-id:uid=0,gid=0)
    else
        userns_flag=(--user "$(id -u):$(id -g)")
    fi
    "$ENGINE" run --rm "${userns_flag[@]}" \
        -v "${AGENTS_VOLUME}:/opt/aidock/agents:z" \
        --entrypoint sh \
        "${BASE_IMAGE_NAME}" \
        -c "npm install -g ${pkgs[*]} && npm cache clean --force"
}

# Inspect $1 (container name) for filesystem changes, and depending on
# $COMMIT_POLICY commit them to $SESSION_IMAGE_NAME or discard them.
# Always rm's the container at the end. $2 is the container exit code,
# used only to skip prompts on signal-style exits if needed in future.
_maybe_commit_container() {
    local cname="$1"
    # Capture diff (ignored when policy is never; cheap so we run it anyway
    # for reporting consistency in always/prompt).
    local changed_lines=0
    local diff_out=""
    if "$ENGINE" container exists "$cname" 2>/dev/null ||
        "$ENGINE" container inspect "$cname" &>/dev/null; then
        diff_out=$("$ENGINE" diff "$cname" 2>/dev/null || true)
    fi
    if [[ -n "$diff_out" ]]; then
        changed_lines=$(printf '%s\n' "$diff_out" | wc -l)
    fi

    local should_commit=false
    if [[ "$changed_lines" -eq 0 ]]; then
        :
    else
        case "$COMMIT_POLICY" in
            always) should_commit=true ;;
            never) should_commit=false ;;
            prompt)
                if _prompt_commit "$changed_lines"; then
                    should_commit=true
                fi
                ;;
        esac
    fi

    if [[ "$should_commit" == "true" ]]; then
        echo "Committing ${changed_lines} filesystem changes to ${SESSION_IMAGE_NAME}..." >&2
        "$ENGINE" commit "$cname" "$SESSION_IMAGE_NAME" >/dev/null
        "$ENGINE" image prune -f >/dev/null 2>&1 || true
    fi

    "$ENGINE" rm -f "$cname" >/dev/null 2>&1 || true
}

# Ask "commit? [Y/n]" with a 10s timeout. Returns 0=commit, 1=discard.
# Empty/Enter still defaults to yes; the *timeout* fallback now defaults
# to no so an unattended terminal doesn't accumulate session images
# silently. Non-tty stdin defaults to yes (automation-style).
_prompt_commit() {
    local n="$1"
    if [[ ! -t 0 ]]; then
        echo "Container changed ${n} paths; committing (non-interactive default)." >&2
        return 0
    fi
    echo "" >&2
    echo "Container changed ${n} paths." >&2
    local reply=""
    if read -r -t 10 -p "Commit to ${SESSION_IMAGE_NAME}? [Y/n] " reply </dev/tty 2>/dev/null; then
        case "${reply,,}" in
            n | no) return 1 ;;
            *) return 0 ;;
        esac
    else
        echo "" >&2
        echo "(timeout — defaulting to no)" >&2
        return 1
    fi
}

# ── Derived paths ────────────────────────────────────────────────────
readonly BASE_IMAGE_NAME="${PROJECT_NAME}-base"
readonly AGENTS_VOLUME="${PROJECT_NAME}-agents"
readonly CONTAINER_NAME="${PROJECT_NAME}-$$"
readonly CONTAINER_HOME="/home/${PROJECT_NAME}"
readonly CONFIG_DIR="${XDG_CONFIG_HOME:-$HOME/.config}/${PROJECT_NAME}"
readonly SESSION_DIR="${XDG_DATA_HOME:-$HOME/.local/share}/${PROJECT_NAME}/sessions"

# ── Session identity ────────────────────────────────────────────────
# Each working directory gets its own committed image. The hash is
# derived from the realpath of the project root so all agents on a CWD
# share state, and a CWD's identity survives symlink resolution.

compute_session_hash() {
    local root="$1"
    local resolved
    resolved=$(readlink -f "$root" 2>/dev/null || echo "$root")
    printf '%s' "$resolved" | sha256sum | head -c 12
}

session_image_name() {
    printf '%s-session-%s' "$PROJECT_NAME" "$1"
}

# ── Default assets location ──────────────────────────────────────────
# ── Default file contents (inlined) ─────────────────────────────────
# These heredocs are the canonical source for the build files. On first
# run they are written to BUILD_DIR; user edits there are preserved.

emit_containerfile() {
    cat <<'__AIDOCK_CONTAINERFILE__'
# aidock: Agent-agnostic AI dev container
# Provides formatters, toolchains, and AI coding agents (copilot, claude, codex).
# LSPs and MCP servers are intentionally not pre-installed; agents install them
# on demand and the per-CWD commit-on-exit persists those installs.
# Build: just build
# See justfile for convenience recipes

FROM fedora:latest

ARG PROJECT_NAME

# ── Base system tools ────────────────────────────────────────────────
RUN dnf install -y \
        # Version control
        git git-lfs openssh-clients \
        # Networking
        curl wget ca-certificates \
        # Search & navigation
        jq ripgrep fd-find tree file less \
        # Archives
        tar gzip xz unzip p7zip \
        # Text & data
        diffutils patch \
        # Process management
        which procps-ng findutils \
        # Runtimes & compilers
        nodejs npm python3 python3-pip \
        # Database
        sqlite \
        # Shell tools
        ShellCheck just sudo \
    && dnf clean all

# ── Formatters via npm ───────────────────────────────────────────────
# LSPs and MCP servers are intentionally NOT pre-installed. Agents
# install per-project tooling on demand and the per-CWD commit-on-exit
# persists those installs across runs.
RUN npm install -g prettier && npm cache clean --force

# ── Shared agents volume mount point ─────────────────────────────────
# AI agent CLIs (copilot/claude/codex) are NOT baked into the base image.
# They are installed into a shared named volume mounted at /opt/aidock/agents
# at build time, so `update-agents` is global and instant across all sessions.
# /opt/aidock/agents/bin is first in PATH; volume binaries shadow image-level
# fallbacks. mode 0777 lets both Podman (root in container) and Docker
# (--user uid:gid) write into the volume.
RUN mkdir -p /opt/aidock/agents/bin /opt/aidock/agents/lib \
    && chmod -R 0777 /opt/aidock/agents
ENV NPM_CONFIG_PREFIX="/opt/aidock/agents"
ENV PATH="/opt/aidock/agents/bin:/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin"

# ── Python formatters ────────────────────────────────────────────────
RUN pip install --break-system-packages ruff

# ── Git identity for container sessions ──────────────────────────────
RUN printf '[user]\n\tname = AI Coding Agent\n\temail = noreply@github.com\n' \
    > /etc/gitconfig

# ── Writable home for container user mapping ─────────────────────────
RUN mkdir -p /home/${PROJECT_NAME} && chmod -R 777 /home/${PROJECT_NAME}
# Allow entrypoint to add passwd entry for Docker --user (no-op under Podman)
RUN chmod 666 /etc/passwd /etc/group
# Passwordless sudo: lets Docker-mapped users install packages at runtime.
# Under Podman (--userns=keep-id:uid=0), the agent is already root so sudo is unnecessary.
RUN echo "ALL ALL=(ALL) NOPASSWD: ALL" > /etc/sudoers.d/agent
ENV HOME="/home/${PROJECT_NAME}"

# ── Entrypoint & healthcheck (the launcher itself) ────────────────────
COPY --chmod=755 aidock /usr/local/bin/aidock

ENV PROJECT_NAME="${PROJECT_NAME}"

ENTRYPOINT ["aidock", "__init-home"]
__AIDOCK_CONTAINERFILE__
}

# Hidden debug flag: print one of the inlined default files and exit.
# Used by `just lint` to pipe the Containerfile through hadolint.
# Inspection-only — does NOT write anywhere.
if [[ "${1:-}" == "--emit-default" ]]; then
    case "${2:-}" in
        Containerfile) emit_containerfile ;;
        *)
            echo "usage: $0 --emit-default Containerfile" >&2
            exit 2
            ;;
    esac
    exit 0
fi

# ── Stage build assets ───────────────────────────────────────────────
# The Containerfile is piped to the build engine via stdin (no disk copy).
# The aidock launcher itself is copied into BUILD_DIR because the
# Containerfile's `COPY aidock …` requires it to exist in the build context.

BUILD_DIR="${CONFIG_DIR}"
mkdir -p "${BUILD_DIR}"

# Sweep stale support files left behind by older versions of aidock.
rm -f "${BUILD_DIR}/init-home.sh" "${BUILD_DIR}/checkhealth.sh" \
    "${BUILD_DIR}/Containerfile" "${BUILD_DIR}/.last-build"

# The launcher itself is COPYed into the image as the entrypoint host. Only
# refresh the staged copy when the source bytes actually changed.
if ! cmp -s "$0" "${BUILD_DIR}/aidock" 2>/dev/null; then
    cp "$0" "${BUILD_DIR}/aidock"
    chmod +x "${BUILD_DIR}/aidock"
fi

# ── aidock.conf (optional) ───────────────────────────────────────────
# Plain bash; sourced if present. Built-in defaults below; CLI flags win.
AIDOCK_CONF="${CONFIG_DIR}/aidock.conf"
commit_on_exit="always"
# shellcheck disable=SC1090
[[ -f "$AIDOCK_CONF" ]] && source "$AIDOCK_CONF"

# ── Parse arguments ──────────────────────────────────────────────────

# Read default agent preference (file contains a single agent name)
DEFAULT_AGENT_FILE="${CONFIG_DIR}/default-agent"
AGENT=""
AGENT_RESOLVED=false
if [[ -f "$DEFAULT_AGENT_FILE" ]]; then
    default_agent=$(<"$DEFAULT_AGENT_FILE")
    default_agent="${default_agent%%[[:space:]]}" # trim trailing whitespace
    default_agent="${default_agent##[[:space:]]}" # trim leading whitespace
    if [[ -n "$default_agent" ]]; then
        AGENT="$default_agent"
        AGENT_RESOLVED=true
    fi
fi

RUN_MODE="run"
AGENT_ARGS=()
EXTRA_CONTAINER_ARGS=()
DRY_RUN=false
BUILD_OVERRIDE=""
AGENT_EXPLICIT=false
FORCE=false
PRUNE_ORPHANS=false
COMMIT_POLICY_OVERRIDE=""

readonly VERSION="0.2.0"

die() {
    echo "error: $*" >&2
    echo "Try '${0##*/} --help' for usage." >&2
    exit 2
}

validate_agent() {
    local name="$1"
    for a in $AVAILABLE_AGENTS; do
        [[ "$a" == "$name" ]] && return 0
    done
    die "unknown agent '${name}' (available: ${AVAILABLE_AGENTS// /, })"
}

# Single source of truth: is <agent> configured for use on this host?
# Returns 0 if a credential is detectable (env var or allowlisted file),
# non-zero otherwise. Does not validate the credential — invalid creds
# fail naturally inside the container.
probe_agent_auth() {
    case "$1" in
        copilot)
            [[ -n "${GH_TOKEN:-}" ]] && return 0
            [[ -f "${HOME}/.config/github-copilot/hosts.json" ]] && return 0
            command -v gh >/dev/null 2>&1 && gh auth token >/dev/null 2>&1 && return 0
            return 1
            ;;
        claude)
            [[ -n "${ANTHROPIC_API_KEY:-}" ]] && return 0
            [[ -f "${HOME}/.claude/.credentials.json" ]] && return 0
            return 1
            ;;
        codex)
            [[ -n "${OPENAI_API_KEY:-}" ]] && return 0
            [[ -f "${HOME}/.codex/auth.json" ]] && return 0
            return 1
            ;;
        *)
            return 1
            ;;
    esac
}

# One-liner setup hint shown when an agent is unconfigured.
agent_setup_hint() {
    case "$1" in
        copilot) echo "Run 'gh auth login' (then enable Copilot), or set GH_TOKEN." ;;
        claude) echo "Set ANTHROPIC_API_KEY, or run 'claude /login' once on the host." ;;
        codex) echo "Set OPENAI_API_KEY, or run 'codex login' once on the host." ;;
        *) echo "Unknown agent: $1" ;;
    esac
}

# Print, one per line, the subset of $AVAILABLE_AGENTS for which
# probe_agent_auth returned success. Cached to avoid repeated probes.
__configured_agents_cache=""
__configured_agents_cached=false
list_configured_agents() {
    if ! $__configured_agents_cached; then
        local out=""
        for a in $AVAILABLE_AGENTS; do
            if probe_agent_auth "$a"; then
                out+="${a}"$'\n'
            fi
        done
        __configured_agents_cache="${out%$'\n'}"
        __configured_agents_cached=true
    fi
    [[ -n "$__configured_agents_cache" ]] && printf '%s\n' "$__configured_agents_cache"
}

# ── Subcommand detection ─────────────────────────────────────────────
# First arg (if not a flag) is treated as a subcommand.

readonly AVAILABLE_COMMANDS="run update clean shell info drop-session purge list-sessions prune"

if [[ $# -gt 0 && "$1" != -* ]]; then
    cmd="$1"
    valid=false
    for c in $AVAILABLE_COMMANDS; do
        [[ "$c" == "$cmd" ]] && valid=true && break
    done
    # Hidden subcommands (used by tests / internals; not advertised)
    [[ "$cmd" == "__check" ]] && valid=true
    if $valid; then
        RUN_MODE="$cmd"
        shift
    fi
fi

# ── Parse flags ──────────────────────────────────────────────────────

while [[ $# -gt 0 ]]; do
    case "$1" in
        -h | --help)
            usage
            ;;
        -v | --version)
            echo "${PROJECT_NAME} ${VERSION}"
            exit 0
            ;;
        -a | --agent)
            [[ $# -ge 2 ]] || die "--agent requires a value"
            [[ "$2" != -* ]] || die "--agent requires a value, got '$2'"
            validate_agent "$2"
            AGENT="$2"
            AGENT_EXPLICIT=true
            AGENT_RESOLVED=true
            shift 2
            ;;
        -n | --dry-run)
            DRY_RUN=true
            shift
            ;;
        --no-cache)
            BUILD_OVERRIDE="force"
            shift
            ;;
        --no-rebuild)
            BUILD_OVERRIDE="skip"
            shift
            ;;
        --force)
            [[ "$RUN_MODE" == "purge" ]] || die "--force is only valid with the 'purge' command"
            FORCE=true
            shift
            ;;
        --orphans)
            [[ "$RUN_MODE" == "prune" ]] || die "--orphans is only valid with the 'prune' command"
            PRUNE_ORPHANS=true
            shift
            ;;
        --commit | --commit=*)
            case "$RUN_MODE" in
                run | shell) ;;
                *) die "--commit is only valid with the 'run' or 'shell' command" ;;
            esac
            if [[ "$1" == --commit=* ]]; then
                value="${1#--commit=}"
                shift
            else
                [[ $# -ge 2 ]] || die "--commit requires a value (always|prompt|never)"
                value="$2"
                shift 2
            fi
            case "$value" in
                always | prompt | never) COMMIT_POLICY_OVERRIDE="$value" ;;
                *) die "--commit value must be one of: always, prompt, never (got '${value}')" ;;
            esac
            ;;
        --)
            shift
            AGENT_ARGS+=("$@")
            break
            ;;
        -*)
            die "unknown option '$1'"
            ;;
        *)
            AGENT_ARGS+=("$@")
            break
            ;;
    esac
done

# Validate agent name (covers default-agent file and --agent flag)
if [[ "$AGENT_RESOLVED" == "true" ]]; then
    validate_agent "$AGENT"
fi

# ── Agent picker (run mode only, when no explicit choice) ────────────
# When the user hasn't picked an agent and we're entering run mode, drive
# selection from host auth: 0 configured → die, 1 → autopick, 2+ → TTY
# picker. shell/info/check fall through to the legacy copilot fallback
# below.
# shellcheck disable=SC2329  # not currently invoked, but defined for future use
agent_picker_run() {
    local configured=()
    local agent
    for agent in $AVAILABLE_AGENTS; do
        if probe_agent_auth "$agent"; then
            configured+=("$agent")
        fi
    done

    case "${#configured[@]}" in
        0)
            {
                echo "error: no agent is configured on this host"
                echo "configure at least one of:"
                for agent in $AVAILABLE_AGENTS; do
                    echo "  - ${agent}: $(agent_setup_hint "$agent")"
                done
            } >&2
            exit 2
            ;;
        1)
            AGENT="${configured[0]}"
            AGENT_RESOLVED=true
            echo "[info] autoselected agent: ${AGENT} (only configured agent on host)" >&2
            ;;
        *)
            if [[ ! -t 0 ]]; then
                {
                    echo "error: multiple agents configured on this host but no TTY for picker"
                    echo "  set -a <agent>, write a name to ~/.config/aidock/default-agent, or run with a TTY"
                    echo "configured agents: ${configured[*]}"
                } >&2
                exit 2
            fi
            {
                echo "Multiple agents configured on this host. Pick one:"
                echo
                local i=1
                for agent in "${configured[@]}"; do
                    echo "  ${i}) ${agent}"
                    i=$((i + 1))
                done
                local unconfigured=()
                for agent in $AVAILABLE_AGENTS; do
                    local found=false
                    local c
                    for c in "${configured[@]}"; do
                        [[ "$c" == "$agent" ]] && {
                            found=true
                            break
                        }
                    done
                    [[ "$found" == "false" ]] && unconfigured+=("$agent")
                done
                if ((${#unconfigured[@]} > 0)); then
                    echo
                    echo "Not configured (set up auth on the host to enable):"
                    for agent in "${unconfigured[@]}"; do
                        echo "  - ${agent}: $(agent_setup_hint "$agent")"
                    done
                fi
                echo
            } >&2
            local choice
            while true; do
                read -r -p "Agent [1]: " choice </dev/tty
                [[ -z "$choice" ]] && choice=1
                if [[ "$choice" =~ ^[0-9]+$ ]] && ((choice >= 1 && choice <= ${#configured[@]})); then
                    AGENT="${configured[$((choice - 1))]}"
                    AGENT_RESOLVED=true
                    break
                fi
                echo "  invalid choice; enter 1-${#configured[@]}" >&2
            done
            ;;
    esac
}

if [[ "$AGENT_RESOLVED" != "true" && ("$RUN_MODE" == "run" || "$RUN_MODE" == "shell") ]]; then
    agent_picker_run
fi

# ── Agent auth check (run/shell only) ────────────────────────────────
# When the user has explicitly chosen an agent (via --agent or the
# default-agent file), require host auth. shell mode is a debug escape
# hatch — warn instead of dying. The picker above guarantees a configured
# agent in run mode, so this is a no-op in that path.
if [[ "$AGENT_RESOLVED" == "true" ]]; then
    case "$RUN_MODE" in
        run)
            if ! probe_agent_auth "$AGENT"; then
                {
                    echo "error: agent '${AGENT}' is not configured on this host"
                    echo "  $(agent_setup_hint "$AGENT")"
                } >&2
                exit 2
            fi
            ;;
        shell)
            if ! probe_agent_auth "$AGENT"; then
                {
                    echo "warning: agent '${AGENT}' has no host auth (shell mode continues anyway)"
                    echo "  $(agent_setup_hint "$AGENT")"
                } >&2
            fi
            ;;
    esac
fi

# Legacy fallback for info/check without explicit selection: pick copilot
# so the agent dispatch case has a value (run/shell go through the picker
# above so AGENT_RESOLVED is true by the time we get here in those modes).
if [[ "$AGENT_RESOLVED" != "true" ]]; then
    AGENT="copilot"
    validate_agent "$AGENT"
fi

# ── Resolve commit_on_exit policy (CLI flag wins over conf file) ────

if [[ -n "$COMMIT_POLICY_OVERRIDE" ]]; then
    commit_on_exit="$COMMIT_POLICY_OVERRIDE"
fi
case "$commit_on_exit" in
    always | prompt | never) ;;
    *) die "invalid commit_on_exit '${commit_on_exit}' (must be: always, prompt, never)" ;;
esac
readonly COMMIT_POLICY="$commit_on_exit"

# ── Determine mount root (git toplevel or CWD) ──────────────────────
# Computed early so session identity is available to every subcommand.

MOUNT_DIR="$PWD"
if git_root=$(git rev-parse --show-toplevel 2>/dev/null); then
    MOUNT_DIR="$git_root"
fi

SESSION_HASH=$(compute_session_hash "$MOUNT_DIR")
SESSION_IMAGE_NAME=$(session_image_name "$SESSION_HASH")

# ── Handle drop-session (early exit) ────────────────────────────────
# Removes this CWD's committed session image and the session record.
# Next launch starts from the base image, recommitting on exit.

if [[ "$RUN_MODE" == "drop-session" ]]; then
    if [[ "$DRY_RUN" == "true" ]]; then
        echo "[dry-run] Would run: $ENGINE rmi ${SESSION_IMAGE_NAME}"
        echo "[dry-run] Would remove: ${SESSION_DIR}/${SESSION_HASH}"
        echo "[dry-run] Would remove: ${SESSION_DIR}/${SESSION_HASH}.lock"
        exit 0
    fi
    if "$ENGINE" image inspect "${SESSION_IMAGE_NAME}" &>/dev/null; then
        "$ENGINE" rmi "${SESSION_IMAGE_NAME}" >/dev/null 2>&1 &&
            echo "Removed session image ${SESSION_IMAGE_NAME}" ||
            echo "Could not remove session image (may be in use)"
    else
        echo "Session image ${SESSION_IMAGE_NAME} not present (skipped)."
    fi
    rm -f "${SESSION_DIR}/${SESSION_HASH}" "${SESSION_DIR}/${SESSION_HASH}.lock"
    echo "Cleared session record for ${MOUNT_DIR}."
    echo "Next launch will start from ${BASE_IMAGE_NAME}."
    exit 0
fi

# ── Handle purge (early exit) ───────────────────────────────────────
# Destructive: rm -rf the whole config dir (or one agent's subdir with
# --agent X). Session images and records under SESSION_DIR are also
# removed when purging globally. Asks for confirmation unless --force.

if [[ "$RUN_MODE" == "purge" ]]; then
    if [[ "$AGENT_EXPLICIT" == "true" ]]; then
        target="${CONFIG_DIR}/${AGENT}"
        if [[ ! -d "$target" ]]; then
            echo "Nothing to purge: ${target} does not exist."
            exit 0
        fi
        target_size=$(du -sh "$target" 2>/dev/null | cut -f1)
        printf "\033[1;31mWARNING: This will permanently delete ALL data for %s:\033[0m\n" "$AGENT"
        echo "  ${target}/ (${target_size})"
        echo "  This includes config files, session data, and conversation history."
    else
        if [[ ! -d "$CONFIG_DIR" ]]; then
            echo "Nothing to purge: ${CONFIG_DIR} does not exist."
            exit 0
        fi
        target_size=$(du -sh "$CONFIG_DIR" 2>/dev/null | cut -f1)
        printf "\033[1;31mWARNING: This will permanently delete ALL aidock data:\033[0m\n"
        echo "  ${CONFIG_DIR}/ (${target_size})"
        echo "  This includes build files, all agent configs, sessions, and history."
    fi

    if [[ "$DRY_RUN" == "true" ]]; then
        if [[ "$AGENT_EXPLICIT" == "true" ]]; then
            echo "[dry-run] Would remove: ${CONFIG_DIR}/${AGENT}"
        else
            echo "[dry-run] Would remove: ${CONFIG_DIR}"
            echo "[dry-run] Would run: $ENGINE volume rm ${AGENTS_VOLUME}"
        fi
        exit 0
    fi

    if [[ "$FORCE" != "true" ]]; then
        printf "\nContinue? [y/N] "
        read -r confirm
        if [[ "$confirm" != [yY] && "$confirm" != [yY][eE][sS] ]]; then
            echo "Aborted."
            exit 1
        fi
    fi

    if [[ "$AGENT_EXPLICIT" == "true" ]]; then
        rm -rf "${CONFIG_DIR:?}/${AGENT:?}"
        echo "Purged ${AGENT} data: deleted ${CONFIG_DIR}/${AGENT}"
    else
        rm -rf "$CONFIG_DIR"
        echo "Purged all data: deleted ${CONFIG_DIR}"
        if engine_volume_exists "${AGENTS_VOLUME}"; then
            "$ENGINE" volume rm "${AGENTS_VOLUME}" >/dev/null 2>&1 &&
                echo "Removed agents volume ${AGENTS_VOLUME}" ||
                echo "Could not remove agents volume ${AGENTS_VOLUME} (may be in use)"
        fi
    fi
    echo "Defaults will be re-seeded on next run."
    exit 0
fi

# ── Handle list-sessions (early exit) ───────────────────────────────

if [[ "$RUN_MODE" == "list-sessions" ]]; then
    if [[ ! -d "$SESSION_DIR" ]] || [[ -z "$(ls -A "$SESSION_DIR" 2>/dev/null)" ]]; then
        echo "No recorded sessions."
        exit 0
    fi
    printf '%-14s  %-8s  %-10s  %s\n' "HASH" "IMAGE" "SIZE" "CWD"
    for f in "$SESSION_DIR"/*; do
        [[ -f "$f" ]] || continue
        name=$(basename "$f")
        case "$name" in
            *.lock) continue ;;
        esac
        cwd=$(head -n1 "$f" 2>/dev/null || echo "?")
        img_tag=$(session_image_name "$name")
        if "$ENGINE" image inspect "$img_tag" &>/dev/null; then
            img_state="present"
            img_size=$(engine_image_size "$img_tag")
            [[ -n "$img_size" ]] || img_size="—"
        else
            img_state="missing"
            img_size="—"
        fi
        printf '%-14s  %-8s  %-10s  %s\n' "$name" "$img_state" "$img_size" "$cwd"
    done
    exit 0
fi

# ── Handle prune (early exit) ──────────────────────────────────────
# Drops session records (and their images) whose recorded CWD no longer
# exists on the host. Bare 'prune' is a dry-run; 'prune --orphans'
# actually removes. No --older-than / size-based pruning yet.

if [[ "$RUN_MODE" == "prune" ]]; then
    if [[ ! -d "$SESSION_DIR" ]] || [[ -z "$(ls -A "$SESSION_DIR" 2>/dev/null)" ]]; then
        echo "No recorded sessions."
        exit 0
    fi

    orphans=()
    for f in "$SESSION_DIR"/*; do
        [[ -f "$f" ]] || continue
        name=$(basename "$f")
        case "$name" in
            *.lock) continue ;;
        esac
        cwd=$(head -n1 "$f" 2>/dev/null || true)
        if [[ -z "$cwd" || ! -d "$cwd" ]]; then
            orphans+=("$name")
        fi
    done

    if [[ ${#orphans[@]} -eq 0 ]]; then
        echo "No orphan sessions found."
        exit 0
    fi

    if [[ "$PRUNE_ORPHANS" != "true" ]]; then
        echo "Orphan sessions (CWD no longer exists on host):"
        for name in "${orphans[@]}"; do
            cwd=$(head -n1 "${SESSION_DIR}/${name}" 2>/dev/null || echo "?")
            echo "  ${name}  (was: ${cwd})"
        done
        echo ""
        echo "Run 'aidock prune --orphans' to remove."
        exit 0
    fi

    if [[ "$DRY_RUN" == "true" ]]; then
        for name in "${orphans[@]}"; do
            img_tag=$(session_image_name "$name")
            echo "[dry-run] Would run: $ENGINE rmi ${img_tag}"
            echo "[dry-run] Would remove: ${SESSION_DIR}/${name}"
            echo "[dry-run] Would remove: ${SESSION_DIR}/${name}.lock"
        done
        exit 0
    fi

    for name in "${orphans[@]}"; do
        img_tag=$(session_image_name "$name")
        if "$ENGINE" image inspect "$img_tag" &>/dev/null; then
            "$ENGINE" rmi "$img_tag" >/dev/null 2>&1 &&
                echo "Removed session image ${img_tag}" ||
                echo "Failed to remove image ${img_tag}" >&2
        fi
        rm -f "${SESSION_DIR}/${name}" "${SESSION_DIR}/${name}.lock"
        echo "Removed session record ${name}"
    done
    echo "Pruned ${#orphans[@]} orphan session(s)."
    exit 0
fi

# ── Handle update (early exit) ─────────────────────────────────────
# Refreshes the AI agent CLIs in the shared agents volume. Global across
# all per-CWD sessions: every aidock run mounts the same volume. Does NOT
# rebuild the base image (use clean + next run for that).

if [[ "$RUN_MODE" == "update" ]]; then
    update_pkgs=()
    update_agents_list=()
    while IFS= read -r _agent; do
        [[ -n "$_agent" ]] || continue
        update_pkgs+=("$(_agent_npm_pkg "$_agent")")
        update_agents_list+=("$_agent")
    done < <(list_configured_agents)

    if ((${#update_pkgs[@]} == 0)); then
        {
            echo "error: no agent is configured on this host; nothing to update"
            echo "configure at least one of:"
            for _agent in $AVAILABLE_AGENTS; do
                echo "  - ${_agent}: $(agent_setup_hint "$_agent")"
            done
        } >&2
        exit 2
    fi

    if [[ "$DRY_RUN" == "true" ]]; then
        if ! engine_image_exists "${BASE_IMAGE_NAME}"; then
            echo "[dry-run] No base image present; would build first."
            echo "[dry-run] Would run: $ENGINE build --build-arg PROJECT_NAME=${PROJECT_NAME} -t ${BASE_IMAGE_NAME} -f - ${BUILD_DIR} (Containerfile from stdin)"
        fi
        echo "[dry-run] configured agents: ${update_agents_list[*]}"
        echo "[dry-run] Would update ${AGENTS_VOLUME}: npm install -g ${update_pkgs[*]}"
        exit 0
    fi

    if ! engine_image_exists "${BASE_IMAGE_NAME}"; then
        echo "[info] no base image yet; building first..."
        echo "Building ${BASE_IMAGE_NAME} image..."
        emit_containerfile | engine_build --build-arg "PROJECT_NAME=${PROJECT_NAME}" \
            -t "${BASE_IMAGE_NAME}" -f - "${BUILD_DIR}"
        # The build's seed step (below) will install the same agents we
        # were about to update, so we're done after one round.
        _seed_agents_volume
        echo "Done."
        exit 0
    fi

    _seed_agents_volume "Updating"
    echo "Done."
    exit 0
fi

# ── Handle clean (early exit) ──────────────────────────────────────

if [[ "$RUN_MODE" == "clean" ]]; then
    if [[ "$DRY_RUN" == "true" ]]; then
        echo "[dry-run] Would run: $ENGINE rmi ${BASE_IMAGE_NAME}"
        echo "[dry-run] Would run: $ENGINE rmi <all ${PROJECT_NAME}-session-* images>"
        echo "[dry-run] Would run: $ENGINE volume rm ${AGENTS_VOLUME}"
        [[ -d "${CONFIG_DIR}" ]] && echo "[dry-run] Would remove: ${CONFIG_DIR}"
        [[ -d "${SESSION_DIR}" ]] && echo "[dry-run] Would remove: ${SESSION_DIR}"
        echo "[dry-run] Would run: $ENGINE image prune -f"
    else
        echo "Cleaning ${PROJECT_NAME}..."
        "$ENGINE" rmi "${BASE_IMAGE_NAME}" 2>/dev/null && echo "  Removed image ${BASE_IMAGE_NAME}" || echo "  Image ${BASE_IMAGE_NAME} not found (skipped)"
        # Remove any session images for this project
        session_images=$("$ENGINE" images --format '{{.Repository}}:{{.Tag}}' 2>/dev/null | grep -E "^${PROJECT_NAME}-session-[0-9a-f]+:" || true)
        if [[ -n "$session_images" ]]; then
            while IFS= read -r img; do
                "$ENGINE" rmi "$img" >/dev/null 2>&1 && echo "  Removed image ${img}"
            done <<<"$session_images"
        fi
        if engine_volume_exists "${AGENTS_VOLUME}"; then
            "$ENGINE" volume rm "${AGENTS_VOLUME}" >/dev/null 2>&1 &&
                echo "  Removed agents volume ${AGENTS_VOLUME}" ||
                echo "  Could not remove agents volume ${AGENTS_VOLUME} (may be in use)"
        fi
        if [[ -d "${CONFIG_DIR}" ]]; then
            rm -rf "${CONFIG_DIR}"
            echo "  Removed config dir ${CONFIG_DIR}"
        fi
        if [[ -d "${SESSION_DIR}" ]]; then
            rm -rf "${SESSION_DIR}"
            echo "  Removed session dir ${SESSION_DIR}"
        fi
        "$ENGINE" image prune -f >/dev/null 2>&1
        echo "Done."
    fi
    exit 0
fi

# ── Agent definitions ────────────────────────────────────────────────

agent_cmd=()
agent_config_dir=""

case "$AGENT" in
    copilot)
        agent_cmd=(copilot --autopilot --enable-all-github-mcp-tools --yolo --continue)
        agent_config_dir=".copilot"
        ;;
    claude)
        agent_cmd=(claude --continue --dangerously-skip-permissions)
        agent_config_dir=".claude"
        ;;
    codex)
        # codex has no --continue flag; resume the most recent session if one
        # exists, otherwise start fresh. The check runs inside the container.
        # shellcheck disable=SC2016
        agent_cmd=(bash -c 'if [ -n "$(find "$HOME/.codex/sessions" -name "*.jsonl" -print -quit 2>/dev/null)" ]; then exec codex --yolo resume --last "$@"; else exec codex --yolo "$@"; fi' codex)
        agent_config_dir=".codex"
        ;;
    *)
        # Should not reach here — validate_agent() catches this
        die "unknown agent '$AGENT'"
        ;;
esac

# ── Auto-build if image doesn't exist or source files changed ────────

needs_build=false

if [[ "$DRY_RUN" == "true" && "$BUILD_OVERRIDE" != "force" ]] || [[ "$RUN_MODE" == "info" && "$BUILD_OVERRIDE" != "force" ]]; then
    # dry-run/info only inspect state; skip build logic entirely
    needs_build=false
elif [[ "$BUILD_OVERRIDE" == "force" ]]; then
    needs_build=true
elif [[ "$BUILD_OVERRIDE" == "skip" ]]; then
    if ! engine_image_exists "${BASE_IMAGE_NAME}"; then
        die "image '${BASE_IMAGE_NAME}' not found (cannot use --no-rebuild)"
    fi
    needs_build=false
elif ! engine_image_exists "${BASE_IMAGE_NAME}"; then
    needs_build=true
fi

FIRST_RUN=false

if [[ "${needs_build}" == "true" ]]; then
    build_flags=()
    if [[ "$BUILD_OVERRIDE" == "force" ]]; then
        build_flags+=(--no-cache)
    fi
    echo "Building ${BASE_IMAGE_NAME} image..."
    emit_containerfile | engine_build "${build_flags[@]}" --build-arg "PROJECT_NAME=${PROJECT_NAME}" \
        -t "${BASE_IMAGE_NAME}" -f - "${BUILD_DIR}"
    _seed_agents_volume
    FIRST_RUN=true
fi

# ── Resolve active image (session if present, else base) ────────────

if engine_image_exists "${SESSION_IMAGE_NAME}"; then
    ACTIVE_IMAGE="${SESSION_IMAGE_NAME}"
else
    ACTIVE_IMAGE="${BASE_IMAGE_NAME}"
fi

if [[ "$FIRST_RUN" == "true" && "$RUN_MODE" == "run" ]]; then
    echo "First run. Use 'aidock --emit-default Containerfile' to inspect the base image recipe."
fi

# ── Assemble mounts ─────────────────────────────────────────────────

mounts=(
    -v "${MOUNT_DIR}:${MOUNT_DIR}:rw"
    -v "${AGENTS_VOLUME}:/opt/aidock/agents:z"
)

env_vars=(
    -e TERM
    -e LANG
    -e DISPLAY
    -e COLORTERM
    -e EDITOR

    -e "HOME=${CONTAINER_HOME}"
    -e "AGENT=${AGENT}"
    -e "AGENT_CONFIG_DIR=${agent_config_dir}"
    -e "PROJECT_NAME=${PROJECT_NAME}"
    -e "CONTAINER_SESSION_INFO=container=${ENGINE} image=${ACTIVE_IMAGE} agent=${AGENT} host_cwd=${PWD}"
)

# Allocate a TTY only when stdin & stdout are both terminals; this lets pipes
# and CI runs work without spurious "input device is not a TTY" errors.
tty_flags=()
if [[ -t 0 && -t 1 ]]; then
    tty_flags=(-it)
fi

# ── Agent-specific auth ─────────────────────────────────────────────

case "$AGENT" in
    copilot)
        if [[ -n "${GH_TOKEN:-}" ]]; then
            env_vars+=(-e "GH_TOKEN=${GH_TOKEN}")
        elif command -v gh &>/dev/null; then
            gh_token=$(gh auth token 2>/dev/null || true)
            if [[ -n "$gh_token" ]]; then
                env_vars+=(-e "GH_TOKEN=${gh_token}")
            else
                echo "warning: 'gh auth token' returned empty, auth may fail" >&2
            fi
        else
            echo "warning: gh CLI not found, cannot pass auth token" >&2
        fi
        ;;
    claude)
        if [[ -n "${ANTHROPIC_API_KEY:-}" ]]; then
            env_vars+=(-e ANTHROPIC_API_KEY)
        else
            echo "warning: ANTHROPIC_API_KEY not set, auth may fail" >&2
        fi
        ;;
    codex)
        if [[ -n "${OPENAI_API_KEY:-}" ]]; then
            env_vars+=(-e OPENAI_API_KEY)
        else
            echo "warning: OPENAI_API_KEY not set, auth may fail" >&2
        fi
        ;;
esac

# ── Host config bind-mount allowlist (per-agent) ─────────────────────
# Mount allowlisted host auth/account files so login state lives on the
# host and is shared across CWDs. Agent data (chat history, sessions,
# cache) stays inside the per-CWD committed image.

add_host_config_mount() {
    local host_path="$1" container_path="$2"
    if [[ -e "$host_path" ]]; then
        mounts+=(-v "${host_path}:${container_path}:rw")
    fi
}

case "$AGENT" in
    copilot)
        for f in apps.json versions.json hosts.json settings.json; do
            add_host_config_mount \
                "${HOME}/.config/github-copilot/${f}" \
                "${CONTAINER_HOME}/.config/github-copilot/${f}"
        done
        # Skills directory: per-skill prompt overrides
        add_host_config_mount \
            "${HOME}/.config/github-copilot/skills" \
            "${CONTAINER_HOME}/.config/github-copilot/skills"
        ;;
    claude)
        add_host_config_mount \
            "${HOME}/.claude/.credentials.json" \
            "${CONTAINER_HOME}/.claude/.credentials.json"
        add_host_config_mount \
            "${HOME}/.claude/settings.json" \
            "${CONTAINER_HOME}/.claude/settings.json"
        add_host_config_mount \
            "${HOME}/.claude/CLAUDE.md" \
            "${CONTAINER_HOME}/.claude/CLAUDE.md"
        ;;
    codex)
        add_host_config_mount \
            "${HOME}/.codex/auth.json" \
            "${CONTAINER_HOME}/.codex/auth.json"
        add_host_config_mount \
            "${HOME}/.codex/config.toml" \
            "${CONTAINER_HOME}/.codex/config.toml"
        add_host_config_mount \
            "${HOME}/.codex/AGENTS.md" \
            "${CONTAINER_HOME}/.codex/AGENTS.md"
        ;;
esac

# ── Extra engine args from config file ────────────────────────────────

CONTAINER_CONF="${CONFIG_DIR}/container.conf"
if [[ -f "$CONTAINER_CONF" ]]; then
    _conf_args_before=${#EXTRA_CONTAINER_ARGS[@]}
    while IFS= read -r line; do
        # Skip empty lines and comments
        [[ -z "$line" || "$line" =~ ^[[:space:]]*# ]] && continue
        # Split line into words (handles "flag value" pairs like "-v /a:/b:rw")
        read -ra args <<<"$line"
        EXTRA_CONTAINER_ARGS+=("${args[@]}")
    done <"$CONTAINER_CONF"
    _conf_args_added=$((${#EXTRA_CONTAINER_ARGS[@]} - _conf_args_before))
    if ((_conf_args_added > 0)) && [[ "$RUN_MODE" != "info" && "$RUN_MODE" != "__check" ]]; then
        echo "[info] applied ${_conf_args_added} extra container args from ${CONTAINER_CONF}" >&2
    fi
fi

# ── Run ──────────────────────────────────────────────────────────────

if [[ "${RUN_MODE}" == "info" ]]; then
    echo "Engine:        ${ENGINE} ($("$ENGINE" --version 2>/dev/null | head -1))"
    if engine_image_exists "${BASE_IMAGE_NAME}"; then
        echo "Base image:    ${BASE_IMAGE_NAME} (built)"
    else
        echo "Base image:    ${BASE_IMAGE_NAME} (not built)"
    fi
    if engine_image_exists "${SESSION_IMAGE_NAME}"; then
        s_size=$(engine_image_size "${SESSION_IMAGE_NAME}")
        if [[ -n "$s_size" ]]; then
            echo "Session image: ${SESSION_IMAGE_NAME} (committed for this CWD, ${s_size})"
        else
            echo "Session image: ${SESSION_IMAGE_NAME} (committed for this CWD)"
        fi
    else
        echo "Session image: ${SESSION_IMAGE_NAME} (none — first run will use base)"
    fi
    if engine_volume_exists "${AGENTS_VOLUME}"; then
        v_size=$(engine_volume_size "${AGENTS_VOLUME}")
        if [[ -n "$v_size" ]]; then
            echo "Agents volume: ${AGENTS_VOLUME} (shared, ${v_size})"
        else
            echo "Agents volume: ${AGENTS_VOLUME} (shared)"
        fi
    else
        echo "Agents volume: ${AGENTS_VOLUME} (absent — will be seeded on next build)"
    fi
    echo "Session hash:  ${SESSION_HASH} (CWD: ${MOUNT_DIR})"
    echo "Active image:  ${ACTIVE_IMAGE}"
    echo "Commit policy: ${COMMIT_POLICY} (commit_on_exit)"
    echo "Agent:         ${AGENT}"
    if [[ -f "$DEFAULT_AGENT_FILE" ]]; then
        echo "Default agent: $(<"$DEFAULT_AGENT_FILE") (from ${DEFAULT_AGENT_FILE})"
    else
        echo "Default agent: copilot (built-in default)"
    fi
    echo "Config dir:    ${CONFIG_DIR}/"
    echo "Containerfile: inline (use 'aidock --emit-default Containerfile' to inspect)"

    # Show agent versions via a quick container run (if image exists)
    if engine_image_exists "${ACTIVE_IMAGE}"; then
        echo ""
        echo "Agent versions (from ${ACTIVE_IMAGE}):"
        for va in $AVAILABLE_AGENTS; do
            ver=$("$ENGINE" run --rm --entrypoint "$va" "${ACTIVE_IMAGE}" --version 2>/dev/null | head -1 || echo "unknown")
            echo "  ${va}: ${ver}"
        done
    fi
    exit 0
fi

if [[ "${RUN_MODE}" == "__check" ]]; then
    engine_run \
        --rm \
        --name "${CONTAINER_NAME}" \
        --hostname "${PROJECT_NAME}" \
        -w "${PWD}" \
        "${env_vars[@]}" \
        "${mounts[@]}" \
        "${EXTRA_CONTAINER_ARGS[@]+"${EXTRA_CONTAINER_ARGS[@]}"}" \
        "${ACTIVE_IMAGE}" \
        aidock __checkhealth "${AGENT_ARGS[@]+"${AGENT_ARGS[@]}"}"
fi

if [[ "${RUN_MODE}" == "shell" ]]; then
    engine_run_committing \
        "${tty_flags[@]}" \
        --name "${CONTAINER_NAME}" \
        --hostname "${PROJECT_NAME}" \
        -w "${PWD}" \
        "${env_vars[@]}" \
        "${mounts[@]}" \
        "${EXTRA_CONTAINER_ARGS[@]+"${EXTRA_CONTAINER_ARGS[@]}"}" \
        --entrypoint /bin/bash \
        "${ACTIVE_IMAGE}" \
        "${AGENT_ARGS[@]+"${AGENT_ARGS[@]}"}"
fi

# ── Launch agent ────────────────────────────────────────────────────

engine_run_committing \
    "${tty_flags[@]}" \
    --name "${CONTAINER_NAME}" \
    --hostname "${PROJECT_NAME}" \
    -w "${PWD}" \
    "${env_vars[@]}" \
    "${mounts[@]}" \
    "${EXTRA_CONTAINER_ARGS[@]+"${EXTRA_CONTAINER_ARGS[@]}"}" \
    "${ACTIVE_IMAGE}" \
    "${agent_cmd[@]}" "${AGENT_ARGS[@]+"${AGENT_ARGS[@]}"}"
