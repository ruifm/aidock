#!/usr/bin/env bash
# aidock: Launch an AI coding agent inside a container (podman or docker).
# DEV SOURCE — do not install directly. Run 'just dist' to build ./aidock.
# PROJECT_NAME: from env (justfile exports it), else derived from argv[0] basename.
# This means a symlink named "my-agent" will use "my-agent" as the project name.

set -euo pipefail

: "${PROJECT_NAME:=$(basename "$0")}"

readonly AVAILABLE_AGENTS="copilot claude codex"

usage() {
    cat <<EOF
Usage: ${0##*/} [command] [options] [-- agent args...]

Launch an AI coding agent inside a container.

Commands:
  run            Launch agent in container (default if omitted)
  build          Build the container image
  update         Pull latest base image and rebuild everything
  update-agents  Reinstall AI agents inside this CWD's session image
  clean          Remove image, config, and dangling layers
  shell          Open a debug shell in container
  check          Run container healthcheck
  info           Show engine, image, and agent info
  reset          Reset config to defaults (preserves session data)
  list-sessions  List recorded per-CWD sessions

Options:
  -a, --agent NAME   Agent to run (${AVAILABLE_AGENTS// /, }). Default: copilot
  -n, --dry-run      Print container command without executing
  -h, --help         Show this help
  -v, --version      Show version

Command-specific options:
  build:  --no-cache    Force full rebuild (no layer cache)
  run:    --no-rebuild  Skip auto-rebuild check
          --commit POLICY  Override commit_on_exit (always|prompt|never)
  shell:  --commit POLICY  Override commit_on_exit (always|prompt|never)
  reset:  --purge       Delete everything (config + session data); asks confirmation
          --session     Drop the current CWD's session image (back to base)
          --force       Skip confirmation prompt (for scripting)

Agent args:
  Arguments after -- are passed to the agent binary.
  Example: ${0##*/} -a claude -- --verbose

Configuration:
  Agent config+state: \${XDG_CONFIG_HOME:-~/.config}/${PROJECT_NAME}/<agent>/
  Build files:        \${XDG_CONFIG_HOME:-~/.config}/${PROJECT_NAME}/{Containerfile,init-home.sh,...}
                      All seeded from defaults on first run. Edit to customize.
  Default agent:      \${XDG_CONFIG_HOME:-~/.config}/${PROJECT_NAME}/default-agent
  Container args:     \${XDG_CONFIG_HOME:-~/.config}/${PROJECT_NAME}/container.conf
  aidock settings:    \${XDG_CONFIG_HOME:-~/.config}/${PROJECT_NAME}/aidock.conf

Examples:
  ${0##*/}                           # Run default agent (copilot)
  ${0##*/} -a claude                 # Run Claude Code
  ${0##*/} shell                     # Debug shell
  ${0##*/} check                     # Healthcheck
  ${0##*/} info                      # Show diagnostic info
  ${0##*/} reset -a claude           # Re-seed claude config from defaults
  ${0##*/} reset --purge -a claude    # Delete all claude config + session data
  ${0##*/} build --no-cache          # Force full rebuild
  ${0##*/} -a claude -- --verbose    # Pass --verbose to claude
  ${0##*/} -- --help                 # Show agent's own help
EOF
    exit 0
}

# ── Engine detection ─────────────────────────────────────────────────

detect_engine() {
    if [[ -n "${CONTAINER_ENGINE:-}" ]]; then
        ENGINE="$CONTAINER_ENGINE"
        if ! command -v "$ENGINE" &>/dev/null; then
            echo "error: CONTAINER_ENGINE='$ENGINE' not found" >&2
            exit 1
        fi
    elif command -v podman &>/dev/null; then
        ENGINE="podman"
    elif command -v docker &>/dev/null; then
        ENGINE="docker"
    else
        echo "error: neither podman nor docker found" >&2
        exit 1
    fi
}

detect_engine

# ── Engine wrapper functions ─────────────────────────────────────────

engine_build() { "$ENGINE" build "$@"; }

engine_image_exists() {
    if [[ "$ENGINE" == "podman" ]]; then
        "$ENGINE" image exists "$1" 2>/dev/null
    else
        "$ENGINE" image inspect "$1" &>/dev/null
    fi
}

# engine_run execs into the container — this function does not return.
# In dry-run mode, prints the command instead of executing.
# Used for ephemeral commands (check) that must not commit.
engine_run() {
    local userns_flag=()
    if [[ "$ENGINE" == "podman" ]]; then
        # shellcheck disable=SC2054  # comma is part of podman flag syntax, not array separator
        userns_flag=(--userns=keep-id:uid=0,gid=0)
    else
        userns_flag=(--user "$(id -u):$(id -g)")
    fi
    if [[ "$DRY_RUN" == "true" ]]; then
        local cmd
        cmd=$(printf '%q ' "$ENGINE" run "${userns_flag[@]}" "$@")
        cmd=$(echo "$cmd" | sed -E 's/(GH_TOKEN=|ANTHROPIC_API_KEY=|OPENAI_API_KEY=)[^ ]*/\1***REDACTED***/g')
        echo "$cmd"
        exit 0
    fi
    exec "$ENGINE" run "${userns_flag[@]}" "$@"
}

# engine_run_committing runs the container without --rm, waits for it
# to exit, and then applies the COMMIT_POLICY: empty diff or 'never'
# discards; 'always' commits to SESSION_IMAGE_NAME; 'prompt' asks the
# user with a 10s default-yes timeout. Always removes the container
# afterwards. Exits with the container's exit code.
#
# Callers must NOT pass --rm; this function manages container lifetime.
engine_run_committing() {
    local userns_flag=()
    if [[ "$ENGINE" == "podman" ]]; then
        # shellcheck disable=SC2054
        userns_flag=(--userns=keep-id:uid=0,gid=0)
    else
        userns_flag=(--user "$(id -u):$(id -g)")
    fi
    if [[ "$DRY_RUN" == "true" ]]; then
        local cmd
        cmd=$(printf '%q ' "$ENGINE" run "${userns_flag[@]}" "$@")
        cmd=$(echo "$cmd" | sed -E 's/(GH_TOKEN=|ANTHROPIC_API_KEY=|OPENAI_API_KEY=)[^ ]*/\1***REDACTED***/g')
        echo "$cmd"
        echo "[dry-run] commit_on_exit=${COMMIT_POLICY} (would commit non-empty diff to ${SESSION_IMAGE_NAME})"
        echo "[dry-run] session_lock=${SESSION_DIR}/${SESSION_HASH}.lock"
        exit 0
    fi
    _record_session
    _acquire_session_lock
    local rc=0
    "$ENGINE" run "${userns_flag[@]}" "$@" || rc=$?
    _maybe_commit_container "$CONTAINER_NAME" "$rc"
    exit "$rc"
}

# Persist hash -> CWD mapping so list-sessions and reset --session can
# show meaningful names. Cheap (a tiny file write).
_record_session() {
    mkdir -p "$SESSION_DIR"
    printf '%s\n' "$MOUNT_DIR" >"${SESSION_DIR}/${SESSION_HASH}"
}

# Acquire an exclusive flock on ${SESSION_DIR}/<hash>.lock so concurrent
# invocations on the same CWD serialize. The lock is released
# automatically when this process exits (kernel unwinds open fds).
_acquire_session_lock() {
    if ! command -v flock >/dev/null 2>&1; then
        return 0
    fi
    mkdir -p "$SESSION_DIR"
    local lockfile="${SESSION_DIR}/${SESSION_HASH}.lock"
    exec 9>"$lockfile"
    if ! flock -n 9; then
        echo "Another aidock session is active in this CWD; waiting..." >&2
        flock 9
    fi
}

# Inspect $1 (container name) for filesystem changes, and depending on
# $COMMIT_POLICY commit them to $SESSION_IMAGE_NAME or discard them.
# Always rm's the container at the end. $2 is the container exit code,
# used only to skip prompts on signal-style exits if needed in future.
_maybe_commit_container() {
    local cname="$1"
    # Capture diff (ignored when policy is never; cheap so we run it anyway
    # for reporting consistency in always/prompt).
    local changed_lines=0
    local diff_out=""
    if "$ENGINE" container exists "$cname" 2>/dev/null ||
        "$ENGINE" container inspect "$cname" &>/dev/null; then
        diff_out=$("$ENGINE" diff "$cname" 2>/dev/null || true)
    fi
    if [[ -n "$diff_out" ]]; then
        changed_lines=$(printf '%s\n' "$diff_out" | wc -l)
    fi

    local should_commit=false
    if [[ "$changed_lines" -eq 0 ]]; then
        :
    else
        case "$COMMIT_POLICY" in
            always) should_commit=true ;;
            never) should_commit=false ;;
            prompt)
                if _prompt_commit "$changed_lines"; then
                    should_commit=true
                fi
                ;;
        esac
    fi

    if [[ "$should_commit" == "true" ]]; then
        echo "Committing ${changed_lines} filesystem changes to ${SESSION_IMAGE_NAME}..." >&2
        "$ENGINE" commit "$cname" "$SESSION_IMAGE_NAME" >/dev/null
        "$ENGINE" image prune -f >/dev/null 2>&1 || true
    fi

    "$ENGINE" rm -f "$cname" >/dev/null 2>&1 || true
}

# Ask "commit? [Y/n]" with a 10s default-yes timeout. Returns 0=commit,
# 1=discard. Non-tty stdin defaults to yes.
_prompt_commit() {
    local n="$1"
    if [[ ! -t 0 ]]; then
        echo "Container changed ${n} paths; committing (non-interactive default)." >&2
        return 0
    fi
    echo "" >&2
    echo "Container changed ${n} paths." >&2
    local reply=""
    if read -r -t 10 -p "Commit to ${SESSION_IMAGE_NAME}? [Y/n] " reply </dev/tty 2>/dev/null; then
        case "${reply,,}" in
            n | no) return 1 ;;
            *) return 0 ;;
        esac
    else
        echo "" >&2
        echo "(timeout — defaulting to yes)" >&2
        return 0
    fi
}

# ── Derived paths ────────────────────────────────────────────────────
SCRIPT_DIR="$(cd "$(dirname "$(readlink -f "${BASH_SOURCE[0]}")")" && pwd)"
readonly BASE_IMAGE_NAME="${PROJECT_NAME}-base"
readonly CONTAINER_NAME="${PROJECT_NAME}-$$"
readonly CONTAINER_HOME="/home/${PROJECT_NAME}"
readonly CONFIG_DIR="${XDG_CONFIG_HOME:-$HOME/.config}/${PROJECT_NAME}"
readonly SESSION_DIR="${XDG_DATA_HOME:-$HOME/.local/share}/${PROJECT_NAME}/sessions"

# ── Session identity ────────────────────────────────────────────────
# Each working directory gets its own committed image. The hash is
# derived from the realpath of the project root so all agents on a CWD
# share state, and a CWD's identity survives symlink resolution.

compute_session_hash() {
    local root="$1"
    local resolved
    resolved=$(readlink -f "$root" 2>/dev/null || echo "$root")
    printf '%s' "$resolved" | sha256sum | head -c 12
}

session_image_name() {
    printf '%s-session-%s' "$PROJECT_NAME" "$1"
}

# ── Default assets location ──────────────────────────────────────────
# __DEFAULTS_BEGIN__ (do not edit this marker — used by build-dist.sh)
# Dev mode: defaults live alongside the source in the repo.
_DEFAULTS_DIR=""
get_defaults_dir() {
    if [[ -n "$_DEFAULTS_DIR" ]]; then return 0; fi
    local repo_root="${SCRIPT_DIR}/.."
    if [[ -f "${repo_root}/defaults/Containerfile" ]]; then
        _DEFAULTS_DIR="${repo_root}/defaults"
    elif [[ -f "${CONFIG_DIR}/Containerfile" ]]; then
        _DEFAULTS_DIR="${CONFIG_DIR}"
    else
        echo "error: cannot find Containerfile in ${repo_root} or ${CONFIG_DIR}" >&2
        return 1
    fi
}
# __DEFAULTS_END__

# ── Seed build assets to CONFIG_DIR ──────────────────────────────────
# The user's copy in CONFIG_DIR is what gets built. get_defaults_dir is the seed source.
# cp -n ensures user edits are preserved (only copies if file doesn't exist).

get_defaults_dir || exit 1
BUILD_DIR="${CONFIG_DIR}"
mkdir -p "${BUILD_DIR}"

cp -arn "${_DEFAULTS_DIR}/." "${BUILD_DIR}/" 2>/dev/null || true

# ── Seed aidock.conf with built-in defaults ─────────────────────────
# Plain KEY=VALUE, sourced as bash. CLI flags override these.
AIDOCK_CONF="${CONFIG_DIR}/aidock.conf"
if [[ ! -f "$AIDOCK_CONF" ]]; then
    cat >"$AIDOCK_CONF" <<'AIDOCKCONF'
# aidock configuration. Plain KEY=VALUE; comments allowed.
# CLI flags (e.g. --commit) override values here.

# Behavior on container exit when the container's filesystem changed:
#   always  Commit the change to the per-CWD session image. (default)
#   prompt  Ask interactively (10s default-yes timeout).
#   never   Discard the change.
commit_on_exit=always
AIDOCKCONF
fi

# Source it (KEY=VALUE only). Set defaults first so a missing key is fine.
commit_on_exit="always"
# shellcheck disable=SC1090
[[ -f "$AIDOCK_CONF" ]] && source "$AIDOCK_CONF"

# ── Parse arguments ──────────────────────────────────────────────────

# Read default agent preference (file contains a single agent name)
DEFAULT_AGENT_FILE="${CONFIG_DIR}/default-agent"
if [[ -f "$DEFAULT_AGENT_FILE" ]]; then
    default_agent=$(<"$DEFAULT_AGENT_FILE")
    default_agent="${default_agent%%[[:space:]]}" # trim trailing whitespace
    default_agent="${default_agent##[[:space:]]}" # trim leading whitespace
    if [[ -n "$default_agent" ]]; then
        AGENT="$default_agent"
    fi
else
    AGENT="copilot"
fi

RUN_MODE="run"
AGENT_ARGS=()
EXTRA_CONTAINER_ARGS=()
DRY_RUN=false
BUILD_OVERRIDE=""
AGENT_EXPLICIT=false
PURGE=false
FORCE=false
RESET_SESSION=false
COMMIT_POLICY_OVERRIDE=""

readonly VERSION="0.1.0"

die() {
    echo "error: $*" >&2
    echo "Try '${0##*/} --help' for usage." >&2
    exit 2
}

validate_agent() {
    local name="$1"
    for a in $AVAILABLE_AGENTS; do
        [[ "$a" == "$name" ]] && return 0
    done
    die "unknown agent '${name}' (available: ${AVAILABLE_AGENTS// /, })"
}

# ── Subcommand detection ─────────────────────────────────────────────
# First arg (if not a flag) is treated as a subcommand.

readonly AVAILABLE_COMMANDS="run build update update-agents clean shell check info reset list-sessions"

if [[ $# -gt 0 && "$1" != -* ]]; then
    cmd="$1"
    valid=false
    for c in $AVAILABLE_COMMANDS; do
        [[ "$c" == "$cmd" ]] && valid=true && break
    done
    if $valid; then
        RUN_MODE="$cmd"
        shift
    fi
fi

# ── Parse flags ──────────────────────────────────────────────────────

while [[ $# -gt 0 ]]; do
    case "$1" in
        -h | --help)
            usage
            ;;
        -v | --version)
            echo "${PROJECT_NAME} ${VERSION}"
            exit 0
            ;;
        -a | --agent)
            [[ $# -ge 2 ]] || die "--agent requires a value"
            [[ "$2" != -* ]] || die "--agent requires a value, got '$2'"
            validate_agent "$2"
            AGENT="$2"
            AGENT_EXPLICIT=true
            shift 2
            ;;
        -n | --dry-run)
            DRY_RUN=true
            shift
            ;;
        --no-cache)
            [[ "$RUN_MODE" == "build" ]] || die "--no-cache is only valid with the 'build' command"
            BUILD_OVERRIDE="force"
            shift
            ;;
        --no-rebuild)
            BUILD_OVERRIDE="skip"
            shift
            ;;
        --purge)
            [[ "$RUN_MODE" == "reset" ]] || die "--purge is only valid with the 'reset' command"
            PURGE=true
            shift
            ;;
        --force)
            [[ "$RUN_MODE" == "reset" ]] || die "--force is only valid with the 'reset' command"
            FORCE=true
            shift
            ;;
        --session)
            [[ "$RUN_MODE" == "reset" ]] || die "--session is only valid with the 'reset' command"
            RESET_SESSION=true
            shift
            ;;
        --commit | --commit=*)
            case "$RUN_MODE" in
                run | shell) ;;
                *) die "--commit is only valid with the 'run' or 'shell' command" ;;
            esac
            if [[ "$1" == --commit=* ]]; then
                value="${1#--commit=}"
                shift
            else
                [[ $# -ge 2 ]] || die "--commit requires a value (always|prompt|never)"
                value="$2"
                shift 2
            fi
            case "$value" in
                always | prompt | never) COMMIT_POLICY_OVERRIDE="$value" ;;
                *) die "--commit value must be one of: always, prompt, never (got '${value}')" ;;
            esac
            ;;
        --)
            shift
            AGENT_ARGS+=("$@")
            break
            ;;
        -*)
            die "unknown option '$1'"
            ;;
        *)
            AGENT_ARGS+=("$@")
            break
            ;;
    esac
done

# Validate agent name (covers default-agent file and --agent flag)
validate_agent "$AGENT"

# ── Resolve commit_on_exit policy (CLI flag wins over conf file) ────

if [[ -n "$COMMIT_POLICY_OVERRIDE" ]]; then
    commit_on_exit="$COMMIT_POLICY_OVERRIDE"
fi
case "$commit_on_exit" in
    always | prompt | never) ;;
    *) die "invalid commit_on_exit '${commit_on_exit}' (must be: always, prompt, never)" ;;
esac
readonly COMMIT_POLICY="$commit_on_exit"

# ── Determine mount root (git toplevel or CWD) ──────────────────────
# Computed early so session identity is available to every subcommand.

MOUNT_DIR="$PWD"
if git_root=$(git rev-parse --show-toplevel 2>/dev/null); then
    MOUNT_DIR="$git_root"
fi

SESSION_HASH=$(compute_session_hash "$MOUNT_DIR")
SESSION_IMAGE_NAME=$(session_image_name "$SESSION_HASH")

# ── Handle reset (early exit) ──────────────────────────────────────

if [[ "$RUN_MODE" == "reset" ]]; then
    get_defaults_dir || exit 1

    if [[ "$RESET_SESSION" == "true" ]]; then
        if [[ "$PURGE" == "true" ]]; then
            die "--session and --purge are mutually exclusive"
        fi
        if [[ "$DRY_RUN" == "true" ]]; then
            echo "[dry-run] Would run: $ENGINE rmi ${SESSION_IMAGE_NAME}"
            echo "[dry-run] Would remove: ${SESSION_DIR}/${SESSION_HASH}"
            echo "[dry-run] Would remove: ${SESSION_DIR}/${SESSION_HASH}.lock"
            exit 0
        fi
        if "$ENGINE" image inspect "${SESSION_IMAGE_NAME}" &>/dev/null; then
            "$ENGINE" rmi "${SESSION_IMAGE_NAME}" >/dev/null 2>&1 &&
                echo "Removed session image ${SESSION_IMAGE_NAME}" ||
                echo "Could not remove session image (may be in use)"
        else
            echo "Session image ${SESSION_IMAGE_NAME} not present (skipped)."
        fi
        rm -f "${SESSION_DIR}/${SESSION_HASH}" "${SESSION_DIR}/${SESSION_HASH}.lock"
        echo "Cleared session record for ${MOUNT_DIR}."
        echo "Next launch will start from ${BASE_IMAGE_NAME}."
        exit 0
    fi

    if [[ "$PURGE" == "true" ]]; then
        # Destructive: rm -rf with confirmation
        if [[ "$AGENT_EXPLICIT" == "true" ]]; then
            target="${CONFIG_DIR}/${AGENT}"
            if [[ ! -d "$target" ]]; then
                echo "Nothing to purge: ${target} does not exist."
                exit 0
            fi
            target_size=$(du -sh "$target" 2>/dev/null | cut -f1)
            printf "\033[1;31mWARNING: This will permanently delete ALL data for %s:\033[0m\n" "$AGENT"
            echo "  ${target}/ (${target_size})"
            echo "  This includes config files, session data, and conversation history."
        else
            if [[ ! -d "$CONFIG_DIR" ]]; then
                echo "Nothing to purge: ${CONFIG_DIR} does not exist."
                exit 0
            fi
            target_size=$(du -sh "$CONFIG_DIR" 2>/dev/null | cut -f1)
            printf "\033[1;31mWARNING: This will permanently delete ALL aidock data:\033[0m\n"
            echo "  ${CONFIG_DIR}/ (${target_size})"
            echo "  This includes build files, all agent configs, sessions, and history."
        fi

        if [[ "$FORCE" != "true" ]]; then
            printf "\nContinue? [y/N] "
            read -r confirm
            if [[ "$confirm" != [yY] && "$confirm" != [yY][eE][sS] ]]; then
                echo "Aborted."
                exit 1
            fi
        fi

        if [[ "$AGENT_EXPLICIT" == "true" ]]; then
            rm -rf "${CONFIG_DIR:?}/${AGENT:?}"
            echo "Purged ${AGENT} data: deleted ${CONFIG_DIR}/${AGENT}"
        else
            rm -rf "$CONFIG_DIR"
            echo "Purged all data: deleted ${CONFIG_DIR}"
        fi
        echo "Defaults will be re-seeded on next run."
    else
        # Safe reset: overwrite build files from defaults
        if [[ "$AGENT_EXPLICIT" == "true" ]]; then
            die "reset --agent requires --purge (no agent defaults to restore)"
        fi
        for name in Containerfile init-home.sh checkhealth.sh; do
            src="${_DEFAULTS_DIR}/${name}"
            [[ -f "$src" ]] && cp -f "$src" "${CONFIG_DIR}/"
        done
        rm -f "${CONFIG_DIR}/.last-build"
        echo "Reset build files from defaults (session data preserved)."
        echo "Config dir: ${CONFIG_DIR}/"
        echo "Rebuild will be triggered on next run."
    fi
    exit 0
fi

# ── Handle list-sessions (early exit) ───────────────────────────────

if [[ "$RUN_MODE" == "list-sessions" ]]; then
    if [[ ! -d "$SESSION_DIR" ]] || [[ -z "$(ls -A "$SESSION_DIR" 2>/dev/null)" ]]; then
        echo "No recorded sessions."
        exit 0
    fi
    printf '%-14s  %-8s  %s\n' "HASH" "IMAGE" "CWD"
    for f in "$SESSION_DIR"/*; do
        [[ -f "$f" ]] || continue
        name=$(basename "$f")
        case "$name" in
            *.lock) continue ;;
        esac
        cwd=$(head -n1 "$f" 2>/dev/null || echo "?")
        img_tag=$(session_image_name "$name")
        if "$ENGINE" image inspect "$img_tag" &>/dev/null; then
            img_state="present"
        else
            img_state="missing"
        fi
        printf '%-14s  %-8s  %s\n' "$name" "$img_state" "$cwd"
    done
    exit 0
fi

# ── Handle build (early exit) ──────────────────────────────────────

if [[ "$RUN_MODE" == "build" ]]; then
    build_flags=()
    if [[ "$BUILD_OVERRIDE" == "force" ]]; then
        build_flags+=(--no-cache)
    fi
    if [[ "$DRY_RUN" == "true" ]]; then
        echo "[dry-run] Would run: $ENGINE build ${build_flags[*]} --build-arg PROJECT_NAME=${PROJECT_NAME} -t ${BASE_IMAGE_NAME} -f ${BUILD_DIR}/Containerfile ${BUILD_DIR}"
    else
        if [[ ! -f "${BUILD_DIR}/.last-build" ]]; then
            echo "Building ${BASE_IMAGE_NAME} image (first build may take several minutes)..."
        else
            echo "Building ${BASE_IMAGE_NAME} image..."
        fi
        engine_build "${build_flags[@]}" --build-arg "PROJECT_NAME=${PROJECT_NAME}" \
            -t "${BASE_IMAGE_NAME}" -f "${BUILD_DIR}/Containerfile" "${BUILD_DIR}"
        touch "${BUILD_DIR}/.last-build"
        echo "Done."
    fi
    exit 0
fi

# ── Handle update (early exit) ─────────────────────────────────────

if [[ "$RUN_MODE" == "update" ]]; then
    if [[ "$DRY_RUN" == "true" ]]; then
        echo "[dry-run] Would run: $ENGINE build --pull --no-cache --build-arg PROJECT_NAME=${PROJECT_NAME} -t ${BASE_IMAGE_NAME} -f ${BUILD_DIR}/Containerfile ${BUILD_DIR}"
        echo "[dry-run] Would run: $ENGINE image prune -f"
    else
        echo "Updating ${BASE_IMAGE_NAME} image (pull + no-cache rebuild)..."
        engine_build --build-arg "PROJECT_NAME=${PROJECT_NAME}" \
            --pull --no-cache -t "${BASE_IMAGE_NAME}" -f "${BUILD_DIR}/Containerfile" "${BUILD_DIR}"
        touch "${BUILD_DIR}/.last-build"
        "$ENGINE" image prune -f
        echo "Done."
    fi
    exit 0
fi

# ── Handle clean (early exit) ──────────────────────────────────────

if [[ "$RUN_MODE" == "clean" ]]; then
    if [[ "$DRY_RUN" == "true" ]]; then
        echo "[dry-run] Would run: $ENGINE rmi ${BASE_IMAGE_NAME}"
        echo "[dry-run] Would run: $ENGINE rmi <all ${PROJECT_NAME}-session-* images>"
        [[ -d "${CONFIG_DIR}" ]] && echo "[dry-run] Would remove: ${CONFIG_DIR}"
        [[ -d "${SESSION_DIR}" ]] && echo "[dry-run] Would remove: ${SESSION_DIR}"
        echo "[dry-run] Would run: $ENGINE image prune -f"
    else
        echo "Cleaning ${PROJECT_NAME}..."
        "$ENGINE" rmi "${BASE_IMAGE_NAME}" 2>/dev/null && echo "  Removed image ${BASE_IMAGE_NAME}" || echo "  Image ${BASE_IMAGE_NAME} not found (skipped)"
        # Remove any session images for this project
        session_images=$("$ENGINE" images --format '{{.Repository}}:{{.Tag}}' 2>/dev/null | grep -E "^${PROJECT_NAME}-session-[0-9a-f]+:" || true)
        if [[ -n "$session_images" ]]; then
            while IFS= read -r img; do
                "$ENGINE" rmi "$img" >/dev/null 2>&1 && echo "  Removed image ${img}"
            done <<<"$session_images"
        fi
        if [[ -d "${CONFIG_DIR}" ]]; then
            rm -rf "${CONFIG_DIR}"
            echo "  Removed config dir ${CONFIG_DIR}"
        fi
        if [[ -d "${SESSION_DIR}" ]]; then
            rm -rf "${SESSION_DIR}"
            echo "  Removed session dir ${SESSION_DIR}"
        fi
        "$ENGINE" image prune -f >/dev/null 2>&1
        echo "Done."
    fi
    exit 0
fi

# ── Handle update-agents (early exit) ──────────────────────────────
# Reinstalls AI agents inside the current CWD's active image (session if
# present, else base) and commits the result as the session image. Lets
# users force-pull latest agent versions without rebuilding the base.

if [[ "$RUN_MODE" == "update-agents" ]]; then
    if engine_image_exists "${SESSION_IMAGE_NAME}"; then
        target_image="${SESSION_IMAGE_NAME}"
    elif engine_image_exists "${BASE_IMAGE_NAME}"; then
        target_image="${BASE_IMAGE_NAME}"
    else
        target_image=""
    fi

    if [[ "$DRY_RUN" == "true" ]]; then
        if [[ -z "$target_image" ]]; then
            echo "[dry-run] No image present; would fall through to 'aidock build'."
            exit 0
        fi
        echo "[dry-run] target image: ${target_image}"
        echo "[dry-run] Would run: $ENGINE run --name ${CONTAINER_NAME} --entrypoint sh ${target_image} -c 'npm install -g @github/copilot @anthropic-ai/claude-code @openai/codex && npm cache clean --force'"
        echo "[dry-run] Would run: $ENGINE commit ${CONTAINER_NAME} ${SESSION_IMAGE_NAME}"
        echo "[dry-run] Would run: $ENGINE rm -f ${CONTAINER_NAME}"
        echo "[dry-run] Would run: $ENGINE image prune -f"
        exit 0
    fi

    if [[ -z "$target_image" ]]; then
        die "no image present; run 'aidock build' first"
    fi

    _record_session
    _acquire_session_lock

    echo "Updating agents in ${target_image}..."
    rc=0
    "$ENGINE" run --name "${CONTAINER_NAME}" --entrypoint sh "${target_image}" -c \
        'npm install -g @github/copilot @anthropic-ai/claude-code @openai/codex && npm cache clean --force' || rc=$?

    if [[ $rc -ne 0 ]]; then
        "$ENGINE" rm -f "${CONTAINER_NAME}" >/dev/null 2>&1 || true
        die "agent update failed (npm install exited ${rc})"
    fi

    echo "Committing to ${SESSION_IMAGE_NAME}..."
    "$ENGINE" commit "${CONTAINER_NAME}" "${SESSION_IMAGE_NAME}" >/dev/null
    "$ENGINE" image prune -f >/dev/null 2>&1 || true
    "$ENGINE" rm -f "${CONTAINER_NAME}" >/dev/null 2>&1 || true
    echo "Done."
    exit 0
fi

# ── Agent definitions ────────────────────────────────────────────────

agent_cmd=()
agent_config_dir=""

case "$AGENT" in
    copilot)
        agent_cmd=(copilot --autopilot --enable-all-github-mcp-tools --yolo --resume)
        agent_config_dir=".copilot"
        ;;
    claude)
        agent_cmd=(claude --continue --dangerously-skip-permissions --mcp-config "${CONTAINER_HOME}/.claude/mcp-config.json")
        agent_config_dir=".claude"
        ;;
    codex)
        agent_cmd=(codex --yolo)
        agent_config_dir=".codex"
        ;;
    *)
        # Should not reach here — validate_agent() catches this
        die "unknown agent '$AGENT'"
        ;;
esac

# ── Auto-build if image doesn't exist or source files changed ────────

needs_build=false

if [[ "$DRY_RUN" == "true" && "$BUILD_OVERRIDE" != "force" ]] || [[ "$RUN_MODE" == "info" && "$BUILD_OVERRIDE" != "force" ]]; then
    # dry-run/info only inspect state; skip build logic entirely
    needs_build=false
elif [[ "$BUILD_OVERRIDE" == "force" ]]; then
    needs_build=true
elif [[ "$BUILD_OVERRIDE" == "skip" ]]; then
    if ! engine_image_exists "${BASE_IMAGE_NAME}"; then
        die "image '${BASE_IMAGE_NAME}' not found (cannot use --no-rebuild)"
    fi
    needs_build=false
elif ! engine_image_exists "${BASE_IMAGE_NAME}"; then
    needs_build=true
else
    last_build_marker="${BUILD_DIR}/.last-build"
    if [[ -f "$last_build_marker" ]]; then
        build_epoch=$(stat -c %Y "$last_build_marker")
    else
        build_epoch=0
    fi
    for src in "${BUILD_DIR}/Containerfile" "${BUILD_DIR}/init-home.sh" "${BUILD_DIR}/checkhealth.sh"; do
        if [[ -f "$src" ]] && (($(stat -c %Y "$src") > build_epoch)); then
            needs_build=true
            break
        fi
    done
fi

FIRST_RUN=false

if [[ "${needs_build}" == "true" ]]; then
    if [[ ! -f "${BUILD_DIR}/.last-build" ]]; then
        echo "Building ${BASE_IMAGE_NAME} image (first build may take several minutes)..."
    else
        echo "Building ${BASE_IMAGE_NAME} image..."
    fi
    engine_build --build-arg "PROJECT_NAME=${PROJECT_NAME}" -t "${BASE_IMAGE_NAME}" -f "${BUILD_DIR}/Containerfile" "${BUILD_DIR}"
    touch "${BUILD_DIR}/.last-build"
    FIRST_RUN=true
fi

# ── Resolve active image (session if present, else base) ────────────

if engine_image_exists "${SESSION_IMAGE_NAME}"; then
    ACTIVE_IMAGE="${SESSION_IMAGE_NAME}"
else
    ACTIVE_IMAGE="${BASE_IMAGE_NAME}"
fi

if [[ "$FIRST_RUN" == "true" && "$RUN_MODE" == "run" ]]; then
    echo "First run. Containerfile: ${BUILD_DIR}/Containerfile"
    echo "Edit files to customize. Use 'reset' to restore defaults."
fi

# ── Assemble mounts ─────────────────────────────────────────────────

mounts=(
    -v "${MOUNT_DIR}:${MOUNT_DIR}:rw"
)

env_vars=(
    -e TERM
    -e LANG
    -e DISPLAY
    -e FIRECRAWL_API_KEY

    -e "HOME=${CONTAINER_HOME}"
    -e "AGENT=${AGENT}"
    -e "AGENT_CONFIG_DIR=${agent_config_dir}"
    -e "PROJECT_NAME=${PROJECT_NAME}"
    -e "CONTAINER_SESSION_INFO=container=${ENGINE} image=${ACTIVE_IMAGE} agent=${AGENT} host_cwd=${PWD}"
)

# ── Agent-specific auth ─────────────────────────────────────────────

case "$AGENT" in
    copilot)
        if [[ -n "${GH_TOKEN:-}" ]]; then
            env_vars+=(-e "GH_TOKEN=${GH_TOKEN}")
        elif command -v gh &>/dev/null; then
            gh_token=$(gh auth token 2>/dev/null || true)
            if [[ -n "$gh_token" ]]; then
                env_vars+=(-e "GH_TOKEN=${gh_token}")
            else
                echo "warning: 'gh auth token' returned empty, auth may fail" >&2
            fi
        else
            echo "warning: gh CLI not found, cannot pass auth token" >&2
        fi
        ;;
    claude)
        if [[ -n "${ANTHROPIC_API_KEY:-}" ]]; then
            env_vars+=(-e ANTHROPIC_API_KEY)
        else
            echo "warning: ANTHROPIC_API_KEY not set, auth may fail" >&2
        fi
        ;;
    codex)
        if [[ -n "${OPENAI_API_KEY:-}" ]]; then
            env_vars+=(-e OPENAI_API_KEY)
        else
            echo "warning: OPENAI_API_KEY not set, auth may fail" >&2
        fi
        ;;
esac

# ── Optional copilot-specific mounts ─────────────────────────────────

if [[ "$AGENT" == "copilot" ]]; then
    if [[ -f "${HOME}/.copilot/copilot-instructions.md" ]]; then
        mounts+=(-v "${HOME}/.copilot/copilot-instructions.md:${CONTAINER_HOME}/.copilot-instructions-host.md:ro")
        env_vars+=(-e "COPILOT_INSTRUCTIONS_HOST=${CONTAINER_HOME}/.copilot-instructions-host.md")
    fi

    if [[ -d "${HOME}/.copilot/agents" ]]; then
        mounts+=(-v "${HOME}/.copilot/agents/:${CONTAINER_HOME}/.copilot-agents-host/:ro")
    fi
fi

# ── Extra engine args from config file ────────────────────────────────

CONTAINER_CONF="${CONFIG_DIR}/container.conf"
if [[ -f "$CONTAINER_CONF" ]]; then
    while IFS= read -r line; do
        # Skip empty lines and comments
        [[ -z "$line" || "$line" =~ ^[[:space:]]*# ]] && continue
        # Split line into words (handles "flag value" pairs like "-v /a:/b:rw")
        read -ra args <<<"$line"
        EXTRA_CONTAINER_ARGS+=("${args[@]}")
    done <"$CONTAINER_CONF"
fi

# ── Run ──────────────────────────────────────────────────────────────

if [[ "${RUN_MODE}" == "info" ]]; then
    echo "Engine:        ${ENGINE} ($("$ENGINE" --version 2>/dev/null | head -1))"
    if engine_image_exists "${BASE_IMAGE_NAME}"; then
        echo "Base image:    ${BASE_IMAGE_NAME} (built)"
    else
        echo "Base image:    ${BASE_IMAGE_NAME} (not built)"
    fi
    if engine_image_exists "${SESSION_IMAGE_NAME}"; then
        echo "Session image: ${SESSION_IMAGE_NAME} (committed for this CWD)"
    else
        echo "Session image: ${SESSION_IMAGE_NAME} (none — first run will use base)"
    fi
    echo "Session hash:  ${SESSION_HASH} (CWD: ${MOUNT_DIR})"
    echo "Active image:  ${ACTIVE_IMAGE}"
    echo "Commit policy: ${COMMIT_POLICY} (commit_on_exit)"
    echo "Agent:         ${AGENT}"
    if [[ -f "$DEFAULT_AGENT_FILE" ]]; then
        echo "Default agent: $(<"$DEFAULT_AGENT_FILE") (from ${DEFAULT_AGENT_FILE})"
    else
        echo "Default agent: copilot (built-in default)"
    fi
    echo "Config dir:    ${CONFIG_DIR}/"
    echo "Containerfile: ${BUILD_DIR}/Containerfile"

    # Show agent versions via a quick container run (if image exists)
    if engine_image_exists "${ACTIVE_IMAGE}"; then
        echo ""
        echo "Agent versions (from ${ACTIVE_IMAGE}):"
        for va in $AVAILABLE_AGENTS; do
            ver=$("$ENGINE" run --rm --entrypoint "$va" "${ACTIVE_IMAGE}" --version 2>/dev/null | head -1 || echo "unknown")
            echo "  ${va}: ${ver}"
        done
    fi
    exit 0
fi

if [[ "${RUN_MODE}" == "check" ]]; then
    engine_run \
        --rm \
        --name "${CONTAINER_NAME}" \
        --hostname "${PROJECT_NAME}" \
        -w "${PWD}" \
        "${env_vars[@]}" \
        "${mounts[@]}" \
        "${EXTRA_CONTAINER_ARGS[@]+"${EXTRA_CONTAINER_ARGS[@]}"}" \
        "${ACTIVE_IMAGE}" \
        checkhealth.sh "${AGENT_ARGS[@]+"${AGENT_ARGS[@]}"}"
fi

if [[ "${RUN_MODE}" == "shell" ]]; then
    engine_run_committing \
        -it \
        --name "${CONTAINER_NAME}" \
        --hostname "${PROJECT_NAME}" \
        -w "${PWD}" \
        "${env_vars[@]}" \
        "${mounts[@]}" \
        "${EXTRA_CONTAINER_ARGS[@]+"${EXTRA_CONTAINER_ARGS[@]}"}" \
        --entrypoint /bin/bash \
        "${ACTIVE_IMAGE}" \
        "${AGENT_ARGS[@]+"${AGENT_ARGS[@]}"}"
fi

# ── Launch agent ────────────────────────────────────────────────────

engine_run_committing \
    -it \
    --name "${CONTAINER_NAME}" \
    --hostname "${PROJECT_NAME}" \
    -w "${PWD}" \
    "${env_vars[@]}" \
    "${mounts[@]}" \
    "${EXTRA_CONTAINER_ARGS[@]+"${EXTRA_CONTAINER_ARGS[@]}"}" \
    "${ACTIVE_IMAGE}" \
    "${agent_cmd[@]}" "${AGENT_ARGS[@]+"${AGENT_ARGS[@]}"}"
