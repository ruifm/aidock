#!/usr/bin/env bash
# aidock: Launch an AI coding agent inside a container (podman or docker).
# This file is the distributed launcher: copy it onto your PATH (e.g. via
# `just install`) and run it directly. There is no dist/build step.
# PROJECT_NAME: from env (justfile exports it), else derived from argv[0] basename.
# This means a symlink named "my-agent" will use "my-agent" as the project name.

set -euo pipefail

: "${PROJECT_NAME:=$(basename "$0")}"

readonly AVAILABLE_AGENTS="copilot claude codex"

usage() {
    cat <<EOF
Usage: ${0##*/} [command] [options] [-- agent args...]

Launch an AI coding agent inside a container.

Commands:
  run            Launch agent in container (default if omitted)
  build          Build the container image
  update         Pull latest base image and rebuild everything
  update-agents  Reinstall AI agents inside this CWD's session image
  clean          Remove image, config, and dangling layers
  shell          Open a debug shell in container
  check          Run container healthcheck
  info           Show engine, image, and agent info
  reset          Reset config to defaults (preserves session data)
  list-sessions  List recorded per-CWD sessions

Options:
  -a, --agent NAME   Agent to run (${AVAILABLE_AGENTS// /, }). Default: copilot
  -n, --dry-run      Print container command without executing
  -h, --help         Show this help
  -v, --version      Show version

Command-specific options:
  build:  --no-cache    Force full rebuild (no layer cache)
  run:    --no-rebuild  Skip auto-rebuild check
          --commit POLICY  Override commit_on_exit (always|prompt|never)
  shell:  --commit POLICY  Override commit_on_exit (always|prompt|never)
  reset:  --purge       Delete everything (config + session data); asks confirmation
          --session     Drop the current CWD's session image (back to base)
          --force       Skip confirmation prompt (for scripting)

Agent args:
  Arguments after -- are passed to the agent binary.
  Example: ${0##*/} -a claude -- --verbose

Configuration:
  Agent config+state: \${XDG_CONFIG_HOME:-~/.config}/${PROJECT_NAME}/<agent>/
  Build files:        \${XDG_CONFIG_HOME:-~/.config}/${PROJECT_NAME}/{Containerfile,init-home.sh,...}
                      All seeded from defaults on first run. Edit to customize.
  Default agent:      \${XDG_CONFIG_HOME:-~/.config}/${PROJECT_NAME}/default-agent
  Container args:     \${XDG_CONFIG_HOME:-~/.config}/${PROJECT_NAME}/container.conf
  aidock settings:    \${XDG_CONFIG_HOME:-~/.config}/${PROJECT_NAME}/aidock.conf

Examples:
  ${0##*/}                           # Run default agent (copilot)
  ${0##*/} -a claude                 # Run Claude Code
  ${0##*/} shell                     # Debug shell
  ${0##*/} check                     # Healthcheck
  ${0##*/} info                      # Show diagnostic info
  ${0##*/} reset -a claude           # Re-seed claude config from defaults
  ${0##*/} reset --purge -a claude    # Delete all claude config + session data
  ${0##*/} build --no-cache          # Force full rebuild
  ${0##*/} -a claude -- --verbose    # Pass --verbose to claude
  ${0##*/} -- --help                 # Show agent's own help
EOF
    exit 0
}

# ── Engine detection ─────────────────────────────────────────────────

detect_engine() {
    if [[ -n "${CONTAINER_ENGINE:-}" ]]; then
        ENGINE="$CONTAINER_ENGINE"
        if ! command -v "$ENGINE" &>/dev/null; then
            echo "error: CONTAINER_ENGINE='$ENGINE' not found" >&2
            exit 1
        fi
    elif command -v podman &>/dev/null; then
        ENGINE="podman"
    elif command -v docker &>/dev/null; then
        ENGINE="docker"
    else
        echo "error: neither podman nor docker found" >&2
        exit 1
    fi
}

detect_engine

# ── Engine wrapper functions ─────────────────────────────────────────

engine_build() { "$ENGINE" build "$@"; }

engine_image_exists() {
    if [[ "$ENGINE" == "podman" ]]; then
        "$ENGINE" image exists "$1" 2>/dev/null
    else
        "$ENGINE" image inspect "$1" &>/dev/null
    fi
}

# engine_run execs into the container — this function does not return.
# In dry-run mode, prints the command instead of executing.
# Used for ephemeral commands (check) that must not commit.
engine_run() {
    local userns_flag=()
    if [[ "$ENGINE" == "podman" ]]; then
        # shellcheck disable=SC2054  # comma is part of podman flag syntax, not array separator
        userns_flag=(--userns=keep-id:uid=0,gid=0)
    else
        userns_flag=(--user "$(id -u):$(id -g)")
    fi
    if [[ "$DRY_RUN" == "true" ]]; then
        local cmd
        cmd=$(printf '%q ' "$ENGINE" run "${userns_flag[@]}" "$@")
        cmd=$(echo "$cmd" | sed -E 's/(GH_TOKEN=|ANTHROPIC_API_KEY=|OPENAI_API_KEY=)[^ ]*/\1***REDACTED***/g')
        echo "$cmd"
        exit 0
    fi
    exec "$ENGINE" run "${userns_flag[@]}" "$@"
}

# engine_run_committing runs the container without --rm, waits for it
# to exit, and then applies the COMMIT_POLICY: empty diff or 'never'
# discards; 'always' commits to SESSION_IMAGE_NAME; 'prompt' asks the
# user with a 10s default-yes timeout. Always removes the container
# afterwards. Exits with the container's exit code.
#
# Callers must NOT pass --rm; this function manages container lifetime.
engine_run_committing() {
    local userns_flag=()
    if [[ "$ENGINE" == "podman" ]]; then
        # shellcheck disable=SC2054
        userns_flag=(--userns=keep-id:uid=0,gid=0)
    else
        userns_flag=(--user "$(id -u):$(id -g)")
    fi
    if [[ "$DRY_RUN" == "true" ]]; then
        local cmd
        cmd=$(printf '%q ' "$ENGINE" run "${userns_flag[@]}" "$@")
        cmd=$(echo "$cmd" | sed -E 's/(GH_TOKEN=|ANTHROPIC_API_KEY=|OPENAI_API_KEY=)[^ ]*/\1***REDACTED***/g')
        echo "$cmd"
        echo "[dry-run] commit_on_exit=${COMMIT_POLICY} (would commit non-empty diff to ${SESSION_IMAGE_NAME})"
        echo "[dry-run] session_lock=${SESSION_DIR}/${SESSION_HASH}.lock"
        exit 0
    fi
    _record_session
    _acquire_session_lock
    local rc=0
    "$ENGINE" run "${userns_flag[@]}" "$@" || rc=$?
    _maybe_commit_container "$CONTAINER_NAME" "$rc"
    exit "$rc"
}

# Persist hash -> CWD mapping so list-sessions and reset --session can
# show meaningful names. Cheap (a tiny file write).
_record_session() {
    mkdir -p "$SESSION_DIR"
    printf '%s\n' "$MOUNT_DIR" >"${SESSION_DIR}/${SESSION_HASH}"
}

# Acquire an exclusive flock on ${SESSION_DIR}/<hash>.lock so concurrent
# invocations on the same CWD serialize. The lock is released
# automatically when this process exits (kernel unwinds open fds).
_acquire_session_lock() {
    if ! command -v flock >/dev/null 2>&1; then
        return 0
    fi
    mkdir -p "$SESSION_DIR"
    local lockfile="${SESSION_DIR}/${SESSION_HASH}.lock"
    exec 9>"$lockfile"
    if ! flock -n 9; then
        echo "Another aidock session is active in this CWD; waiting..." >&2
        flock 9
    fi
}

# Inspect $1 (container name) for filesystem changes, and depending on
# $COMMIT_POLICY commit them to $SESSION_IMAGE_NAME or discard them.
# Always rm's the container at the end. $2 is the container exit code,
# used only to skip prompts on signal-style exits if needed in future.
_maybe_commit_container() {
    local cname="$1"
    # Capture diff (ignored when policy is never; cheap so we run it anyway
    # for reporting consistency in always/prompt).
    local changed_lines=0
    local diff_out=""
    if "$ENGINE" container exists "$cname" 2>/dev/null ||
        "$ENGINE" container inspect "$cname" &>/dev/null; then
        diff_out=$("$ENGINE" diff "$cname" 2>/dev/null || true)
    fi
    if [[ -n "$diff_out" ]]; then
        changed_lines=$(printf '%s\n' "$diff_out" | wc -l)
    fi

    local should_commit=false
    if [[ "$changed_lines" -eq 0 ]]; then
        :
    else
        case "$COMMIT_POLICY" in
            always) should_commit=true ;;
            never) should_commit=false ;;
            prompt)
                if _prompt_commit "$changed_lines"; then
                    should_commit=true
                fi
                ;;
        esac
    fi

    if [[ "$should_commit" == "true" ]]; then
        echo "Committing ${changed_lines} filesystem changes to ${SESSION_IMAGE_NAME}..." >&2
        "$ENGINE" commit "$cname" "$SESSION_IMAGE_NAME" >/dev/null
        "$ENGINE" image prune -f >/dev/null 2>&1 || true
    fi

    "$ENGINE" rm -f "$cname" >/dev/null 2>&1 || true
}

# Ask "commit? [Y/n]" with a 10s default-yes timeout. Returns 0=commit,
# 1=discard. Non-tty stdin defaults to yes.
_prompt_commit() {
    local n="$1"
    if [[ ! -t 0 ]]; then
        echo "Container changed ${n} paths; committing (non-interactive default)." >&2
        return 0
    fi
    echo "" >&2
    echo "Container changed ${n} paths." >&2
    local reply=""
    if read -r -t 10 -p "Commit to ${SESSION_IMAGE_NAME}? [Y/n] " reply </dev/tty 2>/dev/null; then
        case "${reply,,}" in
            n | no) return 1 ;;
            *) return 0 ;;
        esac
    else
        echo "" >&2
        echo "(timeout — defaulting to yes)" >&2
        return 0
    fi
}

# ── Derived paths ────────────────────────────────────────────────────
readonly BASE_IMAGE_NAME="${PROJECT_NAME}-base"
readonly CONTAINER_NAME="${PROJECT_NAME}-$$"
readonly CONTAINER_HOME="/home/${PROJECT_NAME}"
readonly CONFIG_DIR="${XDG_CONFIG_HOME:-$HOME/.config}/${PROJECT_NAME}"
readonly SESSION_DIR="${XDG_DATA_HOME:-$HOME/.local/share}/${PROJECT_NAME}/sessions"

# ── Session identity ────────────────────────────────────────────────
# Each working directory gets its own committed image. The hash is
# derived from the realpath of the project root so all agents on a CWD
# share state, and a CWD's identity survives symlink resolution.

compute_session_hash() {
    local root="$1"
    local resolved
    resolved=$(readlink -f "$root" 2>/dev/null || echo "$root")
    printf '%s' "$resolved" | sha256sum | head -c 12
}

session_image_name() {
    printf '%s-session-%s' "$PROJECT_NAME" "$1"
}

# ── Default assets location ──────────────────────────────────────────
# ── Default file contents (inlined) ─────────────────────────────────
# These heredocs are the canonical source for the build files. On first
# run they are written to BUILD_DIR; user edits there are preserved.

emit_containerfile() {
    cat <<'__AIDOCK_CONTAINERFILE__'
# aidock: Agent-agnostic AI dev container
# Provides LSPs, formatters, toolchains, and AI coding agents (copilot, claude, codex).
# Build: just build
# See justfile for convenience recipes

FROM fedora:latest

ARG PROJECT_NAME

# ── Base system tools ────────────────────────────────────────────────
RUN dnf install -y \
        # Version control
        git git-lfs openssh-clients \
        # Networking
        curl wget ca-certificates \
        # Search & navigation
        jq ripgrep fd-find tree file less \
        # Archives
        tar gzip xz unzip p7zip \
        # Text & data
        diffutils patch \
        # Process management
        which procps-ng findutils \
        # Runtimes & compilers
        nodejs npm python3 python3-pip \
        # Database
        sqlite \
        # Shell tools
        ShellCheck just sudo \
    && dnf clean all

# ── LSPs, MCP servers, AI agents, and formatters via npm ─────────────
RUN npm install -g \
        typescript \
        typescript-language-server \
        bash-language-server \
        dockerfile-language-server-nodejs \
        yaml-language-server \
        vscode-langservers-extracted \
        @upstash/context7-mcp \
        @modelcontextprotocol/server-sequential-thinking \
        @playwright/mcp \
        firecrawl-mcp \
        prettier \
        @github/copilot \
        @anthropic-ai/claude-code \
        @openai/codex \
    && npm cache clean --force

# ── Python packages (LSP and formatters) ─────────────────────────────
RUN pip install --break-system-packages \
        basedpyright ruff

# ── Git identity for container sessions ──────────────────────────────
RUN printf '[user]\n\tname = AI Coding Agent\n\temail = noreply@github.com\n' \
    > /etc/gitconfig

# ── Writable home for container user mapping ─────────────────────────
RUN mkdir -p /home/${PROJECT_NAME} && chmod -R 777 /home/${PROJECT_NAME}
# Allow entrypoint to add passwd entry for Docker --user (no-op under Podman)
RUN chmod 666 /etc/passwd /etc/group
# Passwordless sudo: lets Docker-mapped users install packages at runtime.
# Under Podman (--userns=keep-id:uid=0), the agent is already root so sudo is unnecessary.
RUN echo "ALL ALL=(ALL) NOPASSWD: ALL" > /etc/sudoers.d/agent
ENV HOME="/home/${PROJECT_NAME}"

# ── Entrypoint & healthcheck ──────────────────────────────────────────
COPY --chmod=755 init-home.sh /usr/local/bin/init-home.sh
COPY --chmod=755 checkhealth.sh /usr/local/bin/checkhealth.sh

ENV PROJECT_NAME="${PROJECT_NAME}"

ENTRYPOINT ["/usr/local/bin/init-home.sh"]
__AIDOCK_CONTAINERFILE__
}

emit_init_home() {
    cat <<'__AIDOCK_INIT_HOME__'
#!/usr/bin/env bash
# init-home.sh: Per-container entrypoint. Ensures a writable home for the
# current UID and links any host-mounted configs the agent expects.
#
# All env vars are set by aidock (required).

set -euo pipefail

: "${AGENT:?}" "${AGENT_CONFIG_DIR:?}" "${PROJECT_NAME:?}"

# Ensure current UID has a passwd entry (needed for Docker --user, no-op when running as root)
if [[ "$(id -u)" != "0" ]] && ! getent passwd "$(id -u)" &>/dev/null; then
    echo "${PROJECT_NAME}:x:$(id -u):$(id -g)::${HOME}:/bin/bash" >>/etc/passwd
fi

CONFIG_TARGET="${HOME}/${AGENT_CONFIG_DIR}"

mkdir -p "${CONFIG_TARGET}"

# Agent-specific post-assembly steps
if [[ "$AGENT" == "copilot" ]]; then
    # Link host-mounted copilot-instructions if available
    if [[ -n "${COPILOT_INSTRUCTIONS_HOST:-}" ]] && [[ -f "${COPILOT_INSTRUCTIONS_HOST}" ]]; then
        ln -sfn "${COPILOT_INSTRUCTIONS_HOST}" "${CONFIG_TARGET}/copilot-instructions.md"
    fi

    # Link host-mounted agents if available
    if [[ -d "${HOME}/.copilot-agents-host" ]]; then
        ln -sfn "${HOME}/.copilot-agents-host" "${CONFIG_TARGET}/agents"
    fi
fi

# Set minimal stat checks to avoid reindexing between host and container
if git rev-parse --git-dir &>/dev/null; then
    git config core.checkstat minimal
fi

exec "$@"
__AIDOCK_INIT_HOME__
}

emit_checkhealth() {
    cat <<'__AIDOCK_CHECKHEALTH__'
#!/usr/bin/env bash
# checkhealth.sh: Verify the container environment is correctly configured.
# Run via: just test
# shellcheck disable=SC2015  # A && B || C pattern is intentional for pass/warn reporting
# shellcheck disable=SC2329,SC2317  # check_json is invoked dynamically

set -uo pipefail

: "${AGENT:?}" "${AGENT_CONFIG_DIR:?}" "${PROJECT_NAME:?}"

PASS=0
FAIL=0
WARN=0

pass() {
    printf "  \033[32m✓\033[0m %s\n" "$1"
    PASS=$((PASS + 1))
}
fail() {
    printf "  \033[31m✗\033[0m %s\n" "$1"
    FAIL=$((FAIL + 1))
}
warn() {
    printf "  \033[33m!\033[0m %s\n" "$1"
    WARN=$((WARN + 1))
}
section() { printf "\n\033[1;36m── %s ──\033[0m\n" "$1"; }

check_bin() {
    local name="$1" path="$2"
    if [[ "$path" == "PATH" ]]; then
        if command -v "$name" &>/dev/null; then
            pass "$name ($(command -v "$name"))"
        else
            fail "$name not found in PATH"
        fi
    elif [[ -x "$path" ]]; then
        pass "$name ($path)"
    else
        fail "$name not found at $path"
    fi
}

check_json() {
    local file="$1"
    if [[ ! -f "$file" ]]; then
        fail "$file missing"
    elif jq . "$file" &>/dev/null; then
        pass "$file (valid JSON)"
    else
        fail "$file (invalid JSON)"
    fi
}

# Show whether a config file came from a user override or baked-in default
check_config_source() {
    local basename="$1"
    local config_file="${HOME}/${AGENT_CONFIG_DIR}/${basename}"
    local override="/etc/${PROJECT_NAME}/overrides/${basename}"
    local default="/etc/${PROJECT_NAME}/agents/${AGENT}/${basename}"

    if [[ ! -f "$config_file" ]]; then
        fail "${basename} missing"
        return
    fi

    if ! jq . "$config_file" &>/dev/null; then
        fail "${basename} (invalid JSON)"
        return
    fi

    if [[ -f "$override" ]] && cmp -s "$config_file" "$override"; then
        pass "${basename} (user override)"
    elif [[ -f "$default" ]] && cmp -s "$config_file" "$default"; then
        pass "${basename} (baked-in default)"
    else
        pass "${basename} (valid JSON)"
    fi
}

# ── Environment ──────────────────────────────────────────────────────

section "Environment"

pass "AGENT=$AGENT"
pass "AGENT_CONFIG_DIR=$AGENT_CONFIG_DIR"
pass "PROJECT_NAME=$PROJECT_NAME"

if [[ -d "$HOME" ]] && [[ -w "$HOME" ]]; then
    pass "HOME=$HOME (writable)"
else
    fail "HOME=$HOME (not writable)"
fi

touch "$HOME/.checkhealth-test" 2>/dev/null && rm -f "$HOME/.checkhealth-test" &&
    pass "HOME write test" || fail "HOME write test"

[[ -n "${TERM:-}" ]] && pass "TERM=$TERM" || warn "TERM not set"
[[ -n "${LANG:-}" ]] && pass "LANG=$LANG" || warn "LANG not set"

id_output="$(id -u):$(id -g) ($(whoami 2>/dev/null || echo 'unknown'))"
pass "UID:GID = $id_output"

# ── CWD & mounts ─────────────────────────────────────────────────────

section "CWD & mounts"

cwd="$(pwd)"
pass "CWD=$cwd"

if [[ -d "$cwd" ]] && [[ -r "$cwd" ]]; then
    pass "CWD is readable"
else
    fail "CWD is not readable"
fi

if [[ -w "$cwd" ]]; then
    pass "CWD is writable"
else
    fail "CWD is not writable"
fi

if touch "$cwd/.checkhealth-mount-test" 2>/dev/null; then
    rm -f "$cwd/.checkhealth-mount-test"
    pass "CWD write test"
else
    fail "CWD write test (mount may be ro)"
fi

if ls "$cwd" &>/dev/null && [[ -n "$(ls -A "$cwd" 2>/dev/null)" || -d "$cwd" ]]; then
    file_count=$(find "$cwd" -maxdepth 1 -not -name '.' 2>/dev/null | wc -l)
    pass "CWD has $file_count entries (mount is live)"
else
    warn "CWD appears empty (mount may be missing)"
fi

# ── Agent configs ─────────────────────────────────────────────────────

section "Agent configs ($AGENT)"

# Dynamically check configs based on what's in the agent defaults dir
defaults_dir="/etc/${PROJECT_NAME}/agents/${AGENT}"
if [[ -d "$defaults_dir" ]]; then
    for default_file in "$defaults_dir"/*; do
        [[ -f "$default_file" ]] || continue
        basename="$(basename "$default_file")"
        config_file="${HOME}/${AGENT_CONFIG_DIR}/${basename}"
        if [[ ! -f "$config_file" ]]; then
            fail "${basename} missing"
        elif [[ "$basename" == *.json ]]; then
            check_config_source "$basename"
        elif [[ "$basename" == *.toml ]]; then
            # TOML: just verify the file exists and is non-empty
            if [[ -s "$config_file" ]]; then
                local_override="/etc/${PROJECT_NAME}/overrides/${basename}"
                if [[ -f "$local_override" ]] && cmp -s "$config_file" "$local_override"; then
                    pass "${basename} (user override)"
                elif cmp -s "$config_file" "$default_file"; then
                    pass "${basename} (baked-in default)"
                else
                    pass "${basename} (present)"
                fi
            else
                fail "${basename} (empty)"
            fi
        else
            pass "${basename} (present)"
        fi
    done
else
    warn "no default configs found for agent '$AGENT'"
fi

# Agent-specific config details
case "$AGENT" in
    copilot)
        config_file="${HOME}/${AGENT_CONFIG_DIR}/config.json"
        if [[ -f "$config_file" ]]; then
            model=$(jq -r '.model // "unset"' "$config_file" 2>/dev/null)
            effort=$(jq -r '.effortLevel // "unset"' "$config_file" 2>/dev/null)
            pass "model=$model effortLevel=$effort"
        fi
        ;;
esac

if [[ -w "$HOME/${AGENT_CONFIG_DIR}" ]] && touch "$HOME/${AGENT_CONFIG_DIR}/.session-test" 2>/dev/null; then
    rm -f "$HOME/${AGENT_CONFIG_DIR}/.session-test"
    pass "session data dir writable"
else
    fail "session data dir not writable (sessions will be lost)"
fi

# ── Agent CLI ─────────────────────────────────────────────────────────

section "Agent CLI ($AGENT)"

case "$AGENT" in
    copilot)
        if command -v copilot &>/dev/null; then
            version=$(copilot --version 2>/dev/null || echo "unknown")
            pass "copilot ($version)"
            mcp_output=$(copilot mcp list 2>&1) || true
            if echo "$mcp_output" | grep -q "context7\|sequential-thinking\|playwright\|firecrawl"; then
                registered=$(echo "$mcp_output" | grep -cE "^\s*(context7|sequential-thinking|playwright|firecrawl)" || true)
                pass "copilot mcp list: $registered servers registered"
            else
                warn "copilot mcp list: could not verify MCP servers"
            fi
        else
            fail "copilot not found"
        fi
        ;;
    claude)
        if command -v claude &>/dev/null; then
            version=$(claude --version 2>/dev/null || echo "unknown")
            pass "claude ($version)"
        else
            fail "claude not found"
        fi
        ;;
    codex)
        if command -v codex &>/dev/null; then
            version=$(codex --version 2>/dev/null || echo "unknown")
            pass "codex ($version)"
        else
            fail "codex not found"
        fi
        ;;
esac

# ── Authentication ───────────────────────────────────────────────────

section "Authentication"

case "$AGENT" in
    copilot)
        if [[ -n "${GH_TOKEN:-}" ]]; then
            masked="${GH_TOKEN:0:4}...${GH_TOKEN: -4}"
            pass "GH_TOKEN set ($masked)"
        else
            fail "GH_TOKEN not set (copilot will not authenticate)"
        fi
        ;;
    claude)
        if [[ -n "${ANTHROPIC_API_KEY:-}" ]]; then
            masked="${ANTHROPIC_API_KEY:0:4}...${ANTHROPIC_API_KEY: -4}"
            pass "ANTHROPIC_API_KEY set ($masked)"
        else
            warn "ANTHROPIC_API_KEY not set (claude will not authenticate)"
        fi
        ;;
    codex)
        if [[ -n "${OPENAI_API_KEY:-}" ]]; then
            masked="${OPENAI_API_KEY:0:4}...${OPENAI_API_KEY: -4}"
            pass "OPENAI_API_KEY set ($masked)"
        else
            warn "OPENAI_API_KEY not set (codex will not authenticate)"
        fi
        ;;
esac

# ── Toolchains ───────────────────────────────────────────────────────

section "Toolchains"

if command -v node &>/dev/null; then
    pass "node $(node --version)"
else
    fail "node not found"
fi

if command -v python3 &>/dev/null; then
    pass "python3 $(python3 --version 2>&1 | awk '{print $2}')"
else
    fail "python3 not found"
fi

if command -v gcc &>/dev/null; then
    pass "gcc $(gcc --version | head -1 | grep -oP '\d+\.\d+\.\d+' | head -1)"
else
    warn "gcc not found (install on demand if needed)"
fi

# ── LSP servers ──────────────────────────────────────────────────────

section "LSP servers (7 expected)"

check_bin "typescript-language-server" "/usr/local/bin/typescript-language-server"
check_bin "basedpyright-langserver" "/usr/local/bin/basedpyright-langserver"
check_bin "clangd" "/usr/bin/clangd"
check_bin "bash-language-server" "/usr/local/bin/bash-language-server"
check_bin "docker-langserver" "/usr/local/bin/docker-langserver"
check_bin "yaml-language-server" "/usr/local/bin/yaml-language-server"
check_bin "vscode-json-language-server" "/usr/local/bin/vscode-json-language-server"

# ── MCP servers ──────────────────────────────────────────────────────

section "MCP servers (4 expected)"

check_bin "context7-mcp" "PATH"
check_bin "mcp-server-sequential-thinking" "PATH"
check_bin "playwright-mcp" "PATH"
check_bin "firecrawl-mcp" "PATH"

# ── Formatters & linters ─────────────────────────────────────────────

section "Formatters & linters"

check_bin "ruff" "PATH"
check_bin "prettier" "PATH"
check_bin "shellcheck" "PATH"

# ── Dev tools ────────────────────────────────────────────────────────

section "Dev tools"

for tool in git jq rg fd just curl; do
    check_bin "$tool" "PATH"
done

# ── Git configuration ────────────────────────────────────────────────

section "Git"

git_name=$(git config --get user.name 2>/dev/null || echo "")
git_email=$(git config --get user.email 2>/dev/null || echo "")
if [[ -n "$git_name" && -n "$git_email" ]]; then
    pass "identity: $git_name <$git_email>"
else
    fail "git identity not configured"
fi

if git rev-parse --git-dir &>/dev/null; then
    checkstat=$(git config --get core.checkstat 2>/dev/null || echo "")
    if [[ "$checkstat" == "minimal" ]]; then
        pass "core.checkstat=minimal (reindex protection)"
    else
        warn "core.checkstat not set (entrypoint sets this per-project)"
    fi
    pass "inside git repo: $(git rev-parse --show-toplevel 2>/dev/null)"
else
    warn "not inside a git repo (core.checkstat test skipped)"
fi

# ── MCP server env vars ─────────────────────────────────────────────

section "MCP environment"

[[ -n "${FIRECRAWL_API_KEY:-}" ]] && pass "FIRECRAWL_API_KEY set" || warn "FIRECRAWL_API_KEY not set"

# ── Summary ──────────────────────────────────────────────────────────

printf "\n\033[1m── Summary ──\033[0m\n"
printf "  \033[32m%d passed\033[0m" "$PASS"
[[ $WARN -gt 0 ]] && printf "  \033[33m%d warnings\033[0m" "$WARN"
[[ $FAIL -gt 0 ]] && printf "  \033[31m%d failed\033[0m" "$FAIL"
printf "\n"

exit "$FAIL"
__AIDOCK_CHECKHEALTH__
}

seed_default_file() {
    local name="$1" force="${2:-no}"
    local target="${BUILD_DIR}/${name}"
    if [[ "$force" != "force" && -f "$target" ]]; then
        return 0
    fi
    case "$name" in
        Containerfile) emit_containerfile >"$target" ;;
        init-home.sh)
            emit_init_home >"$target"
            chmod +x "$target"
            ;;
        checkhealth.sh)
            emit_checkhealth >"$target"
            chmod +x "$target"
            ;;
        *)
            echo "error: unknown default file: $name" >&2
            return 1
            ;;
    esac
}

# Hidden debug flag: print one of the inlined default files and exit.
# Used by `just lint` to pipe the Containerfile through hadolint.
if [[ "${1:-}" == "--emit-default" ]]; then
    case "${2:-}" in
        Containerfile) emit_containerfile ;;
        init-home.sh) emit_init_home ;;
        checkhealth.sh) emit_checkhealth ;;
        *)
            echo "usage: $0 --emit-default {Containerfile|init-home.sh|checkhealth.sh}" >&2
            exit 2
            ;;
    esac
    exit 0
fi

# ── Seed build assets to CONFIG_DIR ──────────────────────────────────
# Defaults are emitted from inline heredocs above. cp-style "don't clobber"
# behavior is built into seed_default_file: existing user edits are preserved.

BUILD_DIR="${CONFIG_DIR}"
mkdir -p "${BUILD_DIR}"

for _name in Containerfile init-home.sh checkhealth.sh; do
    seed_default_file "$_name"
done
unset _name

# ── Seed aidock.conf with built-in defaults ─────────────────────────
# Plain KEY=VALUE, sourced as bash. CLI flags override these.
AIDOCK_CONF="${CONFIG_DIR}/aidock.conf"
if [[ ! -f "$AIDOCK_CONF" ]]; then
    cat >"$AIDOCK_CONF" <<'AIDOCKCONF'
# aidock configuration. Plain KEY=VALUE; comments allowed.
# CLI flags (e.g. --commit) override values here.

# Behavior on container exit when the container's filesystem changed:
#   always  Commit the change to the per-CWD session image. (default)
#   prompt  Ask interactively (10s default-yes timeout).
#   never   Discard the change.
commit_on_exit=always
AIDOCKCONF
fi

# Source it (KEY=VALUE only). Set defaults first so a missing key is fine.
commit_on_exit="always"
# shellcheck disable=SC1090
[[ -f "$AIDOCK_CONF" ]] && source "$AIDOCK_CONF"

# ── Parse arguments ──────────────────────────────────────────────────

# Read default agent preference (file contains a single agent name)
DEFAULT_AGENT_FILE="${CONFIG_DIR}/default-agent"
AGENT=""
AGENT_RESOLVED=false
if [[ -f "$DEFAULT_AGENT_FILE" ]]; then
    default_agent=$(<"$DEFAULT_AGENT_FILE")
    default_agent="${default_agent%%[[:space:]]}" # trim trailing whitespace
    default_agent="${default_agent##[[:space:]]}" # trim leading whitespace
    if [[ -n "$default_agent" ]]; then
        AGENT="$default_agent"
        AGENT_RESOLVED=true
    fi
fi

RUN_MODE="run"
AGENT_ARGS=()
EXTRA_CONTAINER_ARGS=()
DRY_RUN=false
BUILD_OVERRIDE=""
AGENT_EXPLICIT=false
PURGE=false
FORCE=false
RESET_SESSION=false
COMMIT_POLICY_OVERRIDE=""

readonly VERSION="0.2.0"

die() {
    echo "error: $*" >&2
    echo "Try '${0##*/} --help' for usage." >&2
    exit 2
}

validate_agent() {
    local name="$1"
    for a in $AVAILABLE_AGENTS; do
        [[ "$a" == "$name" ]] && return 0
    done
    die "unknown agent '${name}' (available: ${AVAILABLE_AGENTS// /, })"
}

# Single source of truth: is <agent> configured for use on this host?
# Returns 0 if a credential is detectable (env var or allowlisted file),
# non-zero otherwise. Does not validate the credential — invalid creds
# fail naturally inside the container.
probe_agent_auth() {
    case "$1" in
        copilot)
            [[ -n "${GH_TOKEN:-}" ]] && return 0
            [[ -f "${HOME}/.config/github-copilot/hosts.json" ]] && return 0
            command -v gh >/dev/null 2>&1 && gh auth token >/dev/null 2>&1 && return 0
            return 1
            ;;
        claude)
            [[ -n "${ANTHROPIC_API_KEY:-}" ]] && return 0
            [[ -f "${HOME}/.claude/.credentials.json" ]] && return 0
            return 1
            ;;
        codex)
            [[ -n "${OPENAI_API_KEY:-}" ]] && return 0
            [[ -f "${HOME}/.codex/auth.json" ]] && return 0
            return 1
            ;;
        *)
            return 1
            ;;
    esac
}

# One-liner setup hint shown when an agent is unconfigured.
agent_setup_hint() {
    case "$1" in
        copilot) echo "Run 'gh auth login' (then enable Copilot), or set GH_TOKEN." ;;
        claude) echo "Set ANTHROPIC_API_KEY, or run 'claude /login' once on the host." ;;
        codex) echo "Set OPENAI_API_KEY, or run 'codex login' once on the host." ;;
        *) echo "Unknown agent: $1" ;;
    esac
}

# Print, one per line, the subset of $AVAILABLE_AGENTS for which
# probe_agent_auth returned success. Cached to avoid repeated probes.
__configured_agents_cache=""
__configured_agents_cached=false
list_configured_agents() {
    if ! $__configured_agents_cached; then
        local out=""
        for a in $AVAILABLE_AGENTS; do
            if probe_agent_auth "$a"; then
                out+="${a}"$'\n'
            fi
        done
        __configured_agents_cache="${out%$'\n'}"
        __configured_agents_cached=true
    fi
    [[ -n "$__configured_agents_cache" ]] && printf '%s\n' "$__configured_agents_cache"
}

# ── Subcommand detection ─────────────────────────────────────────────
# First arg (if not a flag) is treated as a subcommand.

readonly AVAILABLE_COMMANDS="run build update update-agents clean shell check info reset list-sessions"

if [[ $# -gt 0 && "$1" != -* ]]; then
    cmd="$1"
    valid=false
    for c in $AVAILABLE_COMMANDS; do
        [[ "$c" == "$cmd" ]] && valid=true && break
    done
    if $valid; then
        RUN_MODE="$cmd"
        shift
    fi
fi

# ── Parse flags ──────────────────────────────────────────────────────

while [[ $# -gt 0 ]]; do
    case "$1" in
        -h | --help)
            usage
            ;;
        -v | --version)
            echo "${PROJECT_NAME} ${VERSION}"
            exit 0
            ;;
        -a | --agent)
            [[ $# -ge 2 ]] || die "--agent requires a value"
            [[ "$2" != -* ]] || die "--agent requires a value, got '$2'"
            validate_agent "$2"
            AGENT="$2"
            AGENT_EXPLICIT=true
            AGENT_RESOLVED=true
            shift 2
            ;;
        -n | --dry-run)
            DRY_RUN=true
            shift
            ;;
        --no-cache)
            [[ "$RUN_MODE" == "build" ]] || die "--no-cache is only valid with the 'build' command"
            BUILD_OVERRIDE="force"
            shift
            ;;
        --no-rebuild)
            BUILD_OVERRIDE="skip"
            shift
            ;;
        --purge)
            [[ "$RUN_MODE" == "reset" ]] || die "--purge is only valid with the 'reset' command"
            PURGE=true
            shift
            ;;
        --force)
            [[ "$RUN_MODE" == "reset" ]] || die "--force is only valid with the 'reset' command"
            FORCE=true
            shift
            ;;
        --session)
            [[ "$RUN_MODE" == "reset" ]] || die "--session is only valid with the 'reset' command"
            RESET_SESSION=true
            shift
            ;;
        --commit | --commit=*)
            case "$RUN_MODE" in
                run | shell) ;;
                *) die "--commit is only valid with the 'run' or 'shell' command" ;;
            esac
            if [[ "$1" == --commit=* ]]; then
                value="${1#--commit=}"
                shift
            else
                [[ $# -ge 2 ]] || die "--commit requires a value (always|prompt|never)"
                value="$2"
                shift 2
            fi
            case "$value" in
                always | prompt | never) COMMIT_POLICY_OVERRIDE="$value" ;;
                *) die "--commit value must be one of: always, prompt, never (got '${value}')" ;;
            esac
            ;;
        --)
            shift
            AGENT_ARGS+=("$@")
            break
            ;;
        -*)
            die "unknown option '$1'"
            ;;
        *)
            AGENT_ARGS+=("$@")
            break
            ;;
    esac
done

# Validate agent name (covers default-agent file and --agent flag)
if [[ "$AGENT_RESOLVED" == "true" ]]; then
    validate_agent "$AGENT"
fi

# ── Agent picker (run mode only, when no explicit choice) ────────────
# When the user hasn't picked an agent and we're entering run mode, drive
# selection from host auth: 0 configured → die, 1 → autopick, 2+ → TTY
# picker. shell/info/check fall through to the legacy copilot fallback
# below.
# shellcheck disable=SC2329  # not currently invoked, but defined for future use
agent_picker_run() {
    local configured=()
    local agent
    for agent in $AVAILABLE_AGENTS; do
        if probe_agent_auth "$agent"; then
            configured+=("$agent")
        fi
    done

    case "${#configured[@]}" in
        0)
            {
                echo "error: no agent is configured on this host"
                echo "configure at least one of:"
                for agent in $AVAILABLE_AGENTS; do
                    echo "  - ${agent}: $(agent_setup_hint "$agent")"
                done
            } >&2
            exit 2
            ;;
        1)
            AGENT="${configured[0]}"
            AGENT_RESOLVED=true
            echo "[info] autoselected agent: ${AGENT} (only configured agent on host)" >&2
            ;;
        *)
            if [[ ! -t 0 ]]; then
                {
                    echo "error: multiple agents configured on this host but no TTY for picker"
                    echo "  set -a <agent>, write a name to ~/.config/aidock/default-agent, or run with a TTY"
                    echo "configured agents: ${configured[*]}"
                } >&2
                exit 2
            fi
            {
                echo "Multiple agents configured on this host. Pick one:"
                echo
                local i=1
                for agent in "${configured[@]}"; do
                    echo "  ${i}) ${agent}"
                    i=$((i + 1))
                done
                local unconfigured=()
                for agent in $AVAILABLE_AGENTS; do
                    local found=false
                    local c
                    for c in "${configured[@]}"; do
                        [[ "$c" == "$agent" ]] && {
                            found=true
                            break
                        }
                    done
                    [[ "$found" == "false" ]] && unconfigured+=("$agent")
                done
                if ((${#unconfigured[@]} > 0)); then
                    echo
                    echo "Not configured (set up auth on the host to enable):"
                    for agent in "${unconfigured[@]}"; do
                        echo "  - ${agent}: $(agent_setup_hint "$agent")"
                    done
                fi
                echo
            } >&2
            local choice
            while true; do
                read -r -p "Agent [1]: " choice </dev/tty
                [[ -z "$choice" ]] && choice=1
                if [[ "$choice" =~ ^[0-9]+$ ]] && ((choice >= 1 && choice <= ${#configured[@]})); then
                    AGENT="${configured[$((choice - 1))]}"
                    AGENT_RESOLVED=true
                    break
                fi
                echo "  invalid choice; enter 1-${#configured[@]}" >&2
            done
            ;;
    esac
}

if [[ "$AGENT_RESOLVED" != "true" && "$RUN_MODE" == "run" ]]; then
    agent_picker_run
fi

# ── Agent auth check (run/shell only) ────────────────────────────────
# When the user has explicitly chosen an agent (via --agent or the
# default-agent file), require host auth. shell mode is a debug escape
# hatch — warn instead of dying. The picker above guarantees a configured
# agent in run mode, so this is a no-op in that path.
if [[ "$AGENT_RESOLVED" == "true" ]]; then
    case "$RUN_MODE" in
        run)
            if ! probe_agent_auth "$AGENT"; then
                {
                    echo "error: agent '${AGENT}' is not configured on this host"
                    echo "  $(agent_setup_hint "$AGENT")"
                } >&2
                exit 2
            fi
            ;;
        shell)
            if ! probe_agent_auth "$AGENT"; then
                {
                    echo "warning: agent '${AGENT}' has no host auth (shell mode continues anyway)"
                    echo "  $(agent_setup_hint "$AGENT")"
                } >&2
            fi
            ;;
    esac
fi

# Legacy fallback for non-run modes (shell/info/check) without explicit
# selection: pick copilot so the agent dispatch case has a value.
if [[ "$AGENT_RESOLVED" != "true" ]]; then
    AGENT="copilot"
    validate_agent "$AGENT"
fi

# ── Resolve commit_on_exit policy (CLI flag wins over conf file) ────

if [[ -n "$COMMIT_POLICY_OVERRIDE" ]]; then
    commit_on_exit="$COMMIT_POLICY_OVERRIDE"
fi
case "$commit_on_exit" in
    always | prompt | never) ;;
    *) die "invalid commit_on_exit '${commit_on_exit}' (must be: always, prompt, never)" ;;
esac
readonly COMMIT_POLICY="$commit_on_exit"

# ── Determine mount root (git toplevel or CWD) ──────────────────────
# Computed early so session identity is available to every subcommand.

MOUNT_DIR="$PWD"
if git_root=$(git rev-parse --show-toplevel 2>/dev/null); then
    MOUNT_DIR="$git_root"
fi

SESSION_HASH=$(compute_session_hash "$MOUNT_DIR")
SESSION_IMAGE_NAME=$(session_image_name "$SESSION_HASH")

# ── Handle reset (early exit) ──────────────────────────────────────

if [[ "$RUN_MODE" == "reset" ]]; then
    if [[ "$RESET_SESSION" == "true" ]]; then
        if [[ "$PURGE" == "true" ]]; then
            die "--session and --purge are mutually exclusive"
        fi
        if [[ "$DRY_RUN" == "true" ]]; then
            echo "[dry-run] Would run: $ENGINE rmi ${SESSION_IMAGE_NAME}"
            echo "[dry-run] Would remove: ${SESSION_DIR}/${SESSION_HASH}"
            echo "[dry-run] Would remove: ${SESSION_DIR}/${SESSION_HASH}.lock"
            exit 0
        fi
        if "$ENGINE" image inspect "${SESSION_IMAGE_NAME}" &>/dev/null; then
            "$ENGINE" rmi "${SESSION_IMAGE_NAME}" >/dev/null 2>&1 &&
                echo "Removed session image ${SESSION_IMAGE_NAME}" ||
                echo "Could not remove session image (may be in use)"
        else
            echo "Session image ${SESSION_IMAGE_NAME} not present (skipped)."
        fi
        rm -f "${SESSION_DIR}/${SESSION_HASH}" "${SESSION_DIR}/${SESSION_HASH}.lock"
        echo "Cleared session record for ${MOUNT_DIR}."
        echo "Next launch will start from ${BASE_IMAGE_NAME}."
        exit 0
    fi

    if [[ "$PURGE" == "true" ]]; then
        # Destructive: rm -rf with confirmation
        if [[ "$AGENT_EXPLICIT" == "true" ]]; then
            target="${CONFIG_DIR}/${AGENT}"
            if [[ ! -d "$target" ]]; then
                echo "Nothing to purge: ${target} does not exist."
                exit 0
            fi
            target_size=$(du -sh "$target" 2>/dev/null | cut -f1)
            printf "\033[1;31mWARNING: This will permanently delete ALL data for %s:\033[0m\n" "$AGENT"
            echo "  ${target}/ (${target_size})"
            echo "  This includes config files, session data, and conversation history."
        else
            if [[ ! -d "$CONFIG_DIR" ]]; then
                echo "Nothing to purge: ${CONFIG_DIR} does not exist."
                exit 0
            fi
            target_size=$(du -sh "$CONFIG_DIR" 2>/dev/null | cut -f1)
            printf "\033[1;31mWARNING: This will permanently delete ALL aidock data:\033[0m\n"
            echo "  ${CONFIG_DIR}/ (${target_size})"
            echo "  This includes build files, all agent configs, sessions, and history."
        fi

        if [[ "$FORCE" != "true" ]]; then
            printf "\nContinue? [y/N] "
            read -r confirm
            if [[ "$confirm" != [yY] && "$confirm" != [yY][eE][sS] ]]; then
                echo "Aborted."
                exit 1
            fi
        fi

        if [[ "$AGENT_EXPLICIT" == "true" ]]; then
            rm -rf "${CONFIG_DIR:?}/${AGENT:?}"
            echo "Purged ${AGENT} data: deleted ${CONFIG_DIR}/${AGENT}"
        else
            rm -rf "$CONFIG_DIR"
            echo "Purged all data: deleted ${CONFIG_DIR}"
        fi
        echo "Defaults will be re-seeded on next run."
    else
        # Safe reset: overwrite build files from defaults
        if [[ "$AGENT_EXPLICIT" == "true" ]]; then
            die "reset --agent requires --purge (no agent defaults to restore)"
        fi
        for name in Containerfile init-home.sh checkhealth.sh; do
            seed_default_file "$name" force
        done
        rm -f "${CONFIG_DIR}/.last-build"
        echo "Reset build files from defaults (session data preserved)."
        echo "Config dir: ${CONFIG_DIR}/"
        echo "Rebuild will be triggered on next run."
    fi
    exit 0
fi

# ── Handle list-sessions (early exit) ───────────────────────────────

if [[ "$RUN_MODE" == "list-sessions" ]]; then
    if [[ ! -d "$SESSION_DIR" ]] || [[ -z "$(ls -A "$SESSION_DIR" 2>/dev/null)" ]]; then
        echo "No recorded sessions."
        exit 0
    fi
    printf '%-14s  %-8s  %s\n' "HASH" "IMAGE" "CWD"
    for f in "$SESSION_DIR"/*; do
        [[ -f "$f" ]] || continue
        name=$(basename "$f")
        case "$name" in
            *.lock) continue ;;
        esac
        cwd=$(head -n1 "$f" 2>/dev/null || echo "?")
        img_tag=$(session_image_name "$name")
        if "$ENGINE" image inspect "$img_tag" &>/dev/null; then
            img_state="present"
        else
            img_state="missing"
        fi
        printf '%-14s  %-8s  %s\n' "$name" "$img_state" "$cwd"
    done
    exit 0
fi

# ── Handle build (early exit) ──────────────────────────────────────

if [[ "$RUN_MODE" == "build" ]]; then
    build_flags=()
    if [[ "$BUILD_OVERRIDE" == "force" ]]; then
        build_flags+=(--no-cache)
    fi
    if [[ "$DRY_RUN" == "true" ]]; then
        echo "[dry-run] Would run: $ENGINE build ${build_flags[*]} --build-arg PROJECT_NAME=${PROJECT_NAME} -t ${BASE_IMAGE_NAME} -f ${BUILD_DIR}/Containerfile ${BUILD_DIR}"
    else
        if [[ ! -f "${BUILD_DIR}/.last-build" ]]; then
            echo "Building ${BASE_IMAGE_NAME} image (first build may take several minutes)..."
        else
            echo "Building ${BASE_IMAGE_NAME} image..."
        fi
        engine_build "${build_flags[@]}" --build-arg "PROJECT_NAME=${PROJECT_NAME}" \
            -t "${BASE_IMAGE_NAME}" -f "${BUILD_DIR}/Containerfile" "${BUILD_DIR}"
        touch "${BUILD_DIR}/.last-build"
        echo "Done."
    fi
    exit 0
fi

# ── Handle update (early exit) ─────────────────────────────────────

if [[ "$RUN_MODE" == "update" ]]; then
    if [[ "$DRY_RUN" == "true" ]]; then
        echo "[dry-run] Would run: $ENGINE build --pull --no-cache --build-arg PROJECT_NAME=${PROJECT_NAME} -t ${BASE_IMAGE_NAME} -f ${BUILD_DIR}/Containerfile ${BUILD_DIR}"
        echo "[dry-run] Would run: $ENGINE image prune -f"
    else
        echo "Updating ${BASE_IMAGE_NAME} image (pull + no-cache rebuild)..."
        engine_build --build-arg "PROJECT_NAME=${PROJECT_NAME}" \
            --pull --no-cache -t "${BASE_IMAGE_NAME}" -f "${BUILD_DIR}/Containerfile" "${BUILD_DIR}"
        touch "${BUILD_DIR}/.last-build"
        "$ENGINE" image prune -f
        echo "Done."
    fi
    exit 0
fi

# ── Handle clean (early exit) ──────────────────────────────────────

if [[ "$RUN_MODE" == "clean" ]]; then
    if [[ "$DRY_RUN" == "true" ]]; then
        echo "[dry-run] Would run: $ENGINE rmi ${BASE_IMAGE_NAME}"
        echo "[dry-run] Would run: $ENGINE rmi <all ${PROJECT_NAME}-session-* images>"
        [[ -d "${CONFIG_DIR}" ]] && echo "[dry-run] Would remove: ${CONFIG_DIR}"
        [[ -d "${SESSION_DIR}" ]] && echo "[dry-run] Would remove: ${SESSION_DIR}"
        echo "[dry-run] Would run: $ENGINE image prune -f"
    else
        echo "Cleaning ${PROJECT_NAME}..."
        "$ENGINE" rmi "${BASE_IMAGE_NAME}" 2>/dev/null && echo "  Removed image ${BASE_IMAGE_NAME}" || echo "  Image ${BASE_IMAGE_NAME} not found (skipped)"
        # Remove any session images for this project
        session_images=$("$ENGINE" images --format '{{.Repository}}:{{.Tag}}' 2>/dev/null | grep -E "^${PROJECT_NAME}-session-[0-9a-f]+:" || true)
        if [[ -n "$session_images" ]]; then
            while IFS= read -r img; do
                "$ENGINE" rmi "$img" >/dev/null 2>&1 && echo "  Removed image ${img}"
            done <<<"$session_images"
        fi
        if [[ -d "${CONFIG_DIR}" ]]; then
            rm -rf "${CONFIG_DIR}"
            echo "  Removed config dir ${CONFIG_DIR}"
        fi
        if [[ -d "${SESSION_DIR}" ]]; then
            rm -rf "${SESSION_DIR}"
            echo "  Removed session dir ${SESSION_DIR}"
        fi
        "$ENGINE" image prune -f >/dev/null 2>&1
        echo "Done."
    fi
    exit 0
fi

# ── Handle update-agents (early exit) ──────────────────────────────
# Reinstalls AI agents inside the current CWD's active image (session if
# present, else base) and commits the result as the session image. Lets
# users force-pull latest agent versions without rebuilding the base.

if [[ "$RUN_MODE" == "update-agents" ]]; then
    if engine_image_exists "${SESSION_IMAGE_NAME}"; then
        target_image="${SESSION_IMAGE_NAME}"
    elif engine_image_exists "${BASE_IMAGE_NAME}"; then
        target_image="${BASE_IMAGE_NAME}"
    else
        target_image=""
    fi

    # Build the npm install argument list from configured agents only.
    # Avoids pulling unused agents into the per-CWD session image on every
    # refresh.
    declare -A _agent_pkg=(
        [copilot]="@github/copilot"
        [claude]="@anthropic-ai/claude-code"
        [codex]="@openai/codex"
    )
    update_pkgs=()
    update_agents_list=()
    while IFS= read -r _agent; do
        update_pkgs+=("${_agent_pkg[$_agent]}")
        update_agents_list+=("$_agent")
    done < <(list_configured_agents)

    if ((${#update_pkgs[@]} == 0)); then
        {
            echo "error: no agent is configured on this host; nothing to update"
            echo "configure at least one of:"
            for _agent in $AVAILABLE_AGENTS; do
                echo "  - ${_agent}: $(agent_setup_hint "$_agent")"
            done
        } >&2
        exit 2
    fi

    update_cmd="npm install -g ${update_pkgs[*]} && npm cache clean --force"

    if [[ "$DRY_RUN" == "true" ]]; then
        if [[ -z "$target_image" ]]; then
            echo "[dry-run] No image present; would fall through to 'aidock build'."
            exit 0
        fi
        echo "[dry-run] target image: ${target_image}"
        echo "[dry-run] configured agents: ${update_agents_list[*]}"
        echo "[dry-run] Would run: $ENGINE run --name ${CONTAINER_NAME} --entrypoint sh ${target_image} -c '${update_cmd}'"
        echo "[dry-run] Would run: $ENGINE commit ${CONTAINER_NAME} ${SESSION_IMAGE_NAME}"
        echo "[dry-run] Would run: $ENGINE rm -f ${CONTAINER_NAME}"
        echo "[dry-run] Would run: $ENGINE image prune -f"
        exit 0
    fi

    if [[ -z "$target_image" ]]; then
        die "no image present; run 'aidock build' first"
    fi

    _record_session
    _acquire_session_lock

    echo "Updating agents (${update_agents_list[*]}) in ${target_image}..."
    rc=0
    "$ENGINE" run --name "${CONTAINER_NAME}" --entrypoint sh "${target_image}" -c \
        "$update_cmd" || rc=$?

    if [[ $rc -ne 0 ]]; then
        "$ENGINE" rm -f "${CONTAINER_NAME}" >/dev/null 2>&1 || true
        die "agent update failed (npm install exited ${rc})"
    fi

    echo "Committing to ${SESSION_IMAGE_NAME}..."
    "$ENGINE" commit "${CONTAINER_NAME}" "${SESSION_IMAGE_NAME}" >/dev/null
    "$ENGINE" image prune -f >/dev/null 2>&1 || true
    "$ENGINE" rm -f "${CONTAINER_NAME}" >/dev/null 2>&1 || true
    echo "Done."
    exit 0
fi

# ── Agent definitions ────────────────────────────────────────────────

agent_cmd=()
agent_config_dir=""

case "$AGENT" in
    copilot)
        agent_cmd=(copilot --autopilot --enable-all-github-mcp-tools --yolo --resume)
        agent_config_dir=".copilot"
        ;;
    claude)
        agent_cmd=(claude --continue --dangerously-skip-permissions --mcp-config "${CONTAINER_HOME}/.claude/mcp-config.json")
        agent_config_dir=".claude"
        ;;
    codex)
        agent_cmd=(codex --yolo)
        agent_config_dir=".codex"
        ;;
    *)
        # Should not reach here — validate_agent() catches this
        die "unknown agent '$AGENT'"
        ;;
esac

# ── Auto-build if image doesn't exist or source files changed ────────

needs_build=false

if [[ "$DRY_RUN" == "true" && "$BUILD_OVERRIDE" != "force" ]] || [[ "$RUN_MODE" == "info" && "$BUILD_OVERRIDE" != "force" ]]; then
    # dry-run/info only inspect state; skip build logic entirely
    needs_build=false
elif [[ "$BUILD_OVERRIDE" == "force" ]]; then
    needs_build=true
elif [[ "$BUILD_OVERRIDE" == "skip" ]]; then
    if ! engine_image_exists "${BASE_IMAGE_NAME}"; then
        die "image '${BASE_IMAGE_NAME}' not found (cannot use --no-rebuild)"
    fi
    needs_build=false
elif ! engine_image_exists "${BASE_IMAGE_NAME}"; then
    needs_build=true
else
    last_build_marker="${BUILD_DIR}/.last-build"
    if [[ -f "$last_build_marker" ]]; then
        build_epoch=$(stat -c %Y "$last_build_marker")
    else
        build_epoch=0
    fi
    for src in "${BUILD_DIR}/Containerfile" "${BUILD_DIR}/init-home.sh" "${BUILD_DIR}/checkhealth.sh"; do
        if [[ -f "$src" ]] && (($(stat -c %Y "$src") > build_epoch)); then
            needs_build=true
            break
        fi
    done
fi

FIRST_RUN=false

if [[ "${needs_build}" == "true" ]]; then
    if [[ ! -f "${BUILD_DIR}/.last-build" ]]; then
        echo "Building ${BASE_IMAGE_NAME} image (first build may take several minutes)..."
    else
        echo "Building ${BASE_IMAGE_NAME} image..."
    fi
    engine_build --build-arg "PROJECT_NAME=${PROJECT_NAME}" -t "${BASE_IMAGE_NAME}" -f "${BUILD_DIR}/Containerfile" "${BUILD_DIR}"
    touch "${BUILD_DIR}/.last-build"
    FIRST_RUN=true
fi

# ── Resolve active image (session if present, else base) ────────────

if engine_image_exists "${SESSION_IMAGE_NAME}"; then
    ACTIVE_IMAGE="${SESSION_IMAGE_NAME}"
else
    ACTIVE_IMAGE="${BASE_IMAGE_NAME}"
fi

if [[ "$FIRST_RUN" == "true" && "$RUN_MODE" == "run" ]]; then
    echo "First run. Containerfile: ${BUILD_DIR}/Containerfile"
    echo "Edit files to customize. Use 'reset' to restore defaults."
fi

# ── Assemble mounts ─────────────────────────────────────────────────

mounts=(
    -v "${MOUNT_DIR}:${MOUNT_DIR}:rw"
)

env_vars=(
    -e TERM
    -e LANG
    -e DISPLAY
    -e FIRECRAWL_API_KEY

    -e "HOME=${CONTAINER_HOME}"
    -e "AGENT=${AGENT}"
    -e "AGENT_CONFIG_DIR=${agent_config_dir}"
    -e "PROJECT_NAME=${PROJECT_NAME}"
    -e "CONTAINER_SESSION_INFO=container=${ENGINE} image=${ACTIVE_IMAGE} agent=${AGENT} host_cwd=${PWD}"
)

# ── Agent-specific auth ─────────────────────────────────────────────

case "$AGENT" in
    copilot)
        if [[ -n "${GH_TOKEN:-}" ]]; then
            env_vars+=(-e "GH_TOKEN=${GH_TOKEN}")
        elif command -v gh &>/dev/null; then
            gh_token=$(gh auth token 2>/dev/null || true)
            if [[ -n "$gh_token" ]]; then
                env_vars+=(-e "GH_TOKEN=${gh_token}")
            else
                echo "warning: 'gh auth token' returned empty, auth may fail" >&2
            fi
        else
            echo "warning: gh CLI not found, cannot pass auth token" >&2
        fi
        ;;
    claude)
        if [[ -n "${ANTHROPIC_API_KEY:-}" ]]; then
            env_vars+=(-e ANTHROPIC_API_KEY)
        else
            echo "warning: ANTHROPIC_API_KEY not set, auth may fail" >&2
        fi
        ;;
    codex)
        if [[ -n "${OPENAI_API_KEY:-}" ]]; then
            env_vars+=(-e OPENAI_API_KEY)
        else
            echo "warning: OPENAI_API_KEY not set, auth may fail" >&2
        fi
        ;;
esac

# ── Optional copilot-specific mounts ─────────────────────────────────

if [[ "$AGENT" == "copilot" ]]; then
    if [[ -f "${HOME}/.copilot/copilot-instructions.md" ]]; then
        mounts+=(-v "${HOME}/.copilot/copilot-instructions.md:${CONTAINER_HOME}/.copilot-instructions-host.md:ro")
        env_vars+=(-e "COPILOT_INSTRUCTIONS_HOST=${CONTAINER_HOME}/.copilot-instructions-host.md")
    fi

    if [[ -d "${HOME}/.copilot/agents" ]]; then
        mounts+=(-v "${HOME}/.copilot/agents/:${CONTAINER_HOME}/.copilot-agents-host/:ro")
    fi
fi

# ── Host config bind-mount allowlist (per-agent) ─────────────────────
# Mount allowlisted host auth/account files so login state lives on the
# host and is shared across CWDs. Agent data (chat history, sessions,
# cache) stays inside the per-CWD committed image.

add_host_config_mount() {
    local host_path="$1" container_path="$2"
    if [[ -e "$host_path" ]]; then
        mounts+=(-v "${host_path}:${container_path}:rw")
    fi
}

case "$AGENT" in
    copilot)
        for f in apps.json versions.json hosts.json; do
            add_host_config_mount \
                "${HOME}/.config/github-copilot/${f}" \
                "${CONTAINER_HOME}/.config/github-copilot/${f}"
        done
        ;;
    claude)
        add_host_config_mount \
            "${HOME}/.claude/.credentials.json" \
            "${CONTAINER_HOME}/.claude/.credentials.json"
        ;;
    codex)
        add_host_config_mount \
            "${HOME}/.codex/auth.json" \
            "${CONTAINER_HOME}/.codex/auth.json"
        ;;
esac

# ── Extra engine args from config file ────────────────────────────────

CONTAINER_CONF="${CONFIG_DIR}/container.conf"
if [[ -f "$CONTAINER_CONF" ]]; then
    while IFS= read -r line; do
        # Skip empty lines and comments
        [[ -z "$line" || "$line" =~ ^[[:space:]]*# ]] && continue
        # Split line into words (handles "flag value" pairs like "-v /a:/b:rw")
        read -ra args <<<"$line"
        EXTRA_CONTAINER_ARGS+=("${args[@]}")
    done <"$CONTAINER_CONF"
fi

# ── Run ──────────────────────────────────────────────────────────────

if [[ "${RUN_MODE}" == "info" ]]; then
    echo "Engine:        ${ENGINE} ($("$ENGINE" --version 2>/dev/null | head -1))"
    if engine_image_exists "${BASE_IMAGE_NAME}"; then
        echo "Base image:    ${BASE_IMAGE_NAME} (built)"
    else
        echo "Base image:    ${BASE_IMAGE_NAME} (not built)"
    fi
    if engine_image_exists "${SESSION_IMAGE_NAME}"; then
        echo "Session image: ${SESSION_IMAGE_NAME} (committed for this CWD)"
    else
        echo "Session image: ${SESSION_IMAGE_NAME} (none — first run will use base)"
    fi
    echo "Session hash:  ${SESSION_HASH} (CWD: ${MOUNT_DIR})"
    echo "Active image:  ${ACTIVE_IMAGE}"
    echo "Commit policy: ${COMMIT_POLICY} (commit_on_exit)"
    echo "Agent:         ${AGENT}"
    if [[ -f "$DEFAULT_AGENT_FILE" ]]; then
        echo "Default agent: $(<"$DEFAULT_AGENT_FILE") (from ${DEFAULT_AGENT_FILE})"
    else
        echo "Default agent: copilot (built-in default)"
    fi
    echo "Config dir:    ${CONFIG_DIR}/"
    echo "Containerfile: ${BUILD_DIR}/Containerfile"

    # Show agent versions via a quick container run (if image exists)
    if engine_image_exists "${ACTIVE_IMAGE}"; then
        echo ""
        echo "Agent versions (from ${ACTIVE_IMAGE}):"
        for va in $AVAILABLE_AGENTS; do
            ver=$("$ENGINE" run --rm --entrypoint "$va" "${ACTIVE_IMAGE}" --version 2>/dev/null | head -1 || echo "unknown")
            echo "  ${va}: ${ver}"
        done
    fi
    exit 0
fi

if [[ "${RUN_MODE}" == "check" ]]; then
    engine_run \
        --rm \
        --name "${CONTAINER_NAME}" \
        --hostname "${PROJECT_NAME}" \
        -w "${PWD}" \
        "${env_vars[@]}" \
        "${mounts[@]}" \
        "${EXTRA_CONTAINER_ARGS[@]+"${EXTRA_CONTAINER_ARGS[@]}"}" \
        "${ACTIVE_IMAGE}" \
        checkhealth.sh "${AGENT_ARGS[@]+"${AGENT_ARGS[@]}"}"
fi

if [[ "${RUN_MODE}" == "shell" ]]; then
    engine_run_committing \
        -it \
        --name "${CONTAINER_NAME}" \
        --hostname "${PROJECT_NAME}" \
        -w "${PWD}" \
        "${env_vars[@]}" \
        "${mounts[@]}" \
        "${EXTRA_CONTAINER_ARGS[@]+"${EXTRA_CONTAINER_ARGS[@]}"}" \
        --entrypoint /bin/bash \
        "${ACTIVE_IMAGE}" \
        "${AGENT_ARGS[@]+"${AGENT_ARGS[@]}"}"
fi

# ── Launch agent ────────────────────────────────────────────────────

engine_run_committing \
    -it \
    --name "${CONTAINER_NAME}" \
    --hostname "${PROJECT_NAME}" \
    -w "${PWD}" \
    "${env_vars[@]}" \
    "${mounts[@]}" \
    "${EXTRA_CONTAINER_ARGS[@]+"${EXTRA_CONTAINER_ARGS[@]}"}" \
    "${ACTIVE_IMAGE}" \
    "${agent_cmd[@]}" "${AGENT_ARGS[@]+"${AGENT_ARGS[@]}"}"
